{"type":"user","message":{"role":"user","content":[{"tool_use_id":"tool_zjnj0RbnGtrKt7wcH1DNCtFx","type":"tool_result","content":"     1→#!/usr/bin/env python3\n     2→\"\"\"Validate and normalize tasklists.\"\"\"\n     3→\n     4→from __future__ import annotations\n     5→\n     6→import argparse\n     7→import hashlib\n     8→import difflib\n     9→import json\n    10→import re\n    11→import sys\n    12→from dataclasses import dataclass\n    13→from datetime import datetime, timezone\n    14→from pathlib import Path\n    15→from typing import Iterable, List, Optional\n    16→\n    17→import os\n    18→import sys\n    19→from pathlib import Path\n    20→\n    21→\n    22→def _ensure_plugin_root_on_path() -> None:\n    23→    env_root = os.environ.get(\"CLAUDE_PLUGIN_ROOT\", \"\").strip()\n    24→    if env_root:\n    25→        root = Path(env_root).resolve()\n    26→        if (root / \"aidd_runtime\").is_dir():\n    27→            if str(root) not in sys.path:\n    28→                sys.path.insert(0, str(root))\n    29→            return\n    30→\n    31→    probe = Path(__file__).resolve()\n    32→    for parent in (probe.parent, *probe.parents):\n    33→        if (parent / \"aidd_runtime\").is_dir():\n    34→            os.environ.setdefault(\"CLAUDE_PLUGIN_ROOT\", str(parent))\n    35→            if str(parent) not in sys.path:\n    36→                sys.path.insert(0, str(parent))\n    37→            return\n    38→\n    39→\n    40→_ensure_plugin_root_on_path()\n    41→\n    42→from aidd_runtime import gates\n    43→from aidd_runtime import runtime\n    44→from aidd_runtime.feature_ids import resolve_aidd_root, resolve_identifiers\n    45→\n    46→\n    47→PLACEHOLDER_VALUES = {\"\", \"...\", \"<...>\", \"tbd\", \"<tbd>\", \"todo\", \"<todo>\"}\n    48→NONE_VALUES = {\"none\", \"нет\", \"n/a\", \"na\"}\n    49→SPEC_PLACEHOLDERS = {\"none\", \"нет\", \"n/a\", \"na\", \"-\", \"missing\"}\n    50→SPEC_REQUIRED_PATTERNS = [\n    51→    re.compile(pattern, re.IGNORECASE)\n    52→    for pattern in (\n    53→        r\"\\bui\\b\",\n    54→        r\"\\bux\\b\",\n    55→        r\"\\bui/ux\\b\",\n    56→        r\"\\bfrontend\\b\",\n    57→        r\"\\bfront[- ]end\\b\",\n    58→        r\"/ui/\",\n    59→        r\"/ux/\",\n    60→        r\"/frontend/\",\n    61→        r\"/front-end/\",\n    62→        r\"\\bweb\\b\",\n    63→        r\"\\bинтерфейс\",\n    64→        r\"\\bэкран\",\n    65→        r\"\\bстраниц\",\n    66→        r\"\\bформа\\b\",\n    67→        r\"\\bдизайн\\b\",\n    68→        r\"\\bвизуал\",\n    69→        r\"\\bмакет\",\n    70→        r\"\\blayout\\b\",\n    71→        r\"\\bapi\\b\",\n    72→        r\"\\bendpoint\\b\",\n    73→        r\"\\brest\\b\",\n    74→        r\"\\bgrpc\\b\",\n    75→        r\"\\bgraphql\\b\",\n    76→        r\"\\bcontract\\b\",\n    77→        r\"\\bschema\\b\",\n    78→        r\"\\bmigration\\b\",\n    79→        r\"\\bdb\\b\",\n    80→        r\"\\bdatabase\\b\",\n    81→        r\"\\bdata\\b\",\n    82→        r\"\\btable\\b\",\n    83→        r\"\\bcolumn\\b\",\n    84→        r\"\\bконтракт\\b\",\n    85→        r\"\\bсхем\",\n    86→        r\"\\bмиграц\",\n    87→        r\"\\bбаз\",\n    88→        r\"\\bданн\",\n    89→        r\"\\bтаблиц\",\n    90→        r\"\\bколонк\",\n    91→        r\"\\be2e\\b\",\n    92→        r\"\\bend[- ]to[- ]end\\b\",\n    93→        r\"\\bstaging\\b\",\n    94→        r\"\\bstand\\b\",\n    95→        r\"\\bстенд\\b\",\n    96→    )\n    97→]\n    98→\n    99→REQUIRED_SECTIONS = {\n   100→    \"AIDD:CONTEXT_PACK\",\n   101→    \"AIDD:SPEC_PACK\",\n   102→    \"AIDD:TEST_STRATEGY\",\n   103→    \"AIDD:TEST_EXECUTION\",\n   104→    \"AIDD:ITERATIONS_FULL\",\n   105→    \"AIDD:NEXT_3\",\n   106→    \"AIDD:HANDOFF_INBOX\",\n   107→    \"AIDD:QA_TRACEABILITY\",\n   108→    \"AIDD:CHECKLIST\",\n   109→    \"AIDD:PROGRESS_LOG\",\n   110→    \"AIDD:HOW_TO_UPDATE\",\n   111→}\n   112→\n   113→PRIORITY_ORDER = {\"critical\": 0, \"high\": 1, \"medium\": 2, \"low\": 3}\n   114→PRIORITY_VALUES = set(PRIORITY_ORDER)\n   115→HANDOFF_STATUS_VALUES = {\"open\", \"done\", \"blocked\"}\n   116→HANDOFF_SOURCE_VALUES = {\"research\", \"review\", \"qa\", \"manual\"}\n   117→ITERATION_STATE_VALUES = {\"open\", \"done\", \"blocked\"}\n   118→PROGRESS_SOURCES = {\"implement\", \"review\", \"qa\", \"research\", \"normalize\"}\n   119→PROGRESS_KINDS = {\"iteration\", \"handoff\"}\n   120→STRICT_STAGES = {\"review\", \"qa\"}\n   121→\n   122→SECTION_HEADER_RE = re.compile(r\"^##\\s+(.+?)\\s*$\")\n   123→CHECKBOX_RE = re.compile(r\"^\\s*-\\s*\\[(?P<state>[ xX])\\]\\s+(?P<body>.+)$\")\n   124→REF_RE = re.compile(r\"\\bref\\s*:\\s*([^\\)]+)\")\n   125→ID_RE = re.compile(r\"\\bid\\s*:\\s*([A-Za-z0-9_.:-]+)\")\n   126→ITERATION_ID_RE = re.compile(r\"\\biteration_id\\s*[:=]\\s*([A-Za-z0-9_.:-]+)\")\n   127→STATE_RE = re.compile(r\"\\bstate\\s*:\\s*([A-Za-z0-9_-]+)\", re.IGNORECASE)\n   128→PARENT_ITERATION_RE = re.compile(r\"\\bparent_iteration_id\\s*:\\s*([A-Za-z0-9_.:-]+)\", re.IGNORECASE)\n   129→PROGRESS_LINE_RE = re.compile(\n   130→    r\"^\\s*-\\s*(?P<date>\\d{4}-\\d{2}-\\d{2})\\s+\"\n   131→    r\"source=(?P<source>[A-Za-z0-9_-]+)\\s+\"\n   132→    r\"id=(?P<item_id>[A-Za-z0-9_.:-]+)\\s+\"\n   133→    r\"kind=(?P<kind>[A-Za-z0-9_-]+)\\s+\"\n   134→    r\"hash=(?P<hash>[A-Za-z0-9]+)\"\n   135→    r\"(?:\\s+link=(?P<link>\\S+))?\\s+\"\n   136→    r\"msg=(?P<msg>.+)$\"\n   137→)\n   138→\n   139→\n   140→@dataclass\n   141→class Section:\n   142→    title: str\n   143→    start: int\n   144→    end: int\n   145→    lines: List[str]\n   146→\n   147→\n   148→@dataclass\n   149→class Issue:\n   150→    severity: str\n   151→    message: str\n   152→\n   153→\n   154→@dataclass\n   155→class TasklistCheckResult:\n   156→    status: str\n   157→    message: str = \"\"\n   158→    details: List[str] | None = None\n   159→    warnings: List[str] | None = None\n   160→\n   161→    def exit_code(self) -> int:\n   162→        return 0 if self.status in {\"ok\", \"warn\", \"skip\"} else 2\n   163→\n   164→\n   165→@dataclass\n   166→class IterationItem:\n   167→    item_id: str\n   168→    title: str\n   169→    state: str\n   170→    checkbox: str\n   171→    parent_id: str | None\n   172→    explicit_id: bool\n   173→    priority: str\n   174→    blocking: bool\n   175→    deps: List[str]\n   176→    locks: List[str]\n   177→    lines: List[str]\n   178→\n   179→\n   180→@dataclass\n   181→class HandoffItem:\n   182→    item_id: str\n   183→    title: str\n   184→    status: str\n   185→    checkbox: str\n   186→    priority: str\n   187→    blocking: bool\n   188→    source: str\n   189→    lines: List[str]\n   190→\n   191→\n   192→@dataclass\n   193→class WorkItem:\n   194→    kind: str\n   195→    item_id: str\n   196→    title: str\n   197→    priority: str\n   198→    blocking: bool\n   199→    order_key: tuple\n   200→\n   201→\n   202→@dataclass\n   203→class NormalizeResult:\n   204→    updated_text: str\n   205→    summary: List[str]\n   206→    changed: bool\n   207→\n   208→\n   209→def parse_args(argv: Iterable[str] | None = None) -> argparse.Namespace:\n   210→    parser = argparse.ArgumentParser(description=\"Validate tasklist readiness.\")\n   211→    parser.add_argument(\"--ticket\", default=None, help=\"Feature ticket (defaults to docs/.active.json).\")\n   212→    parser.add_argument(\"--slug-hint\", default=None, help=\"Optional slug hint override.\")\n   213→    parser.add_argument(\"--branch\", default=\"\", help=\"Current branch name for branch filters.\")\n   214→    parser.add_argument(\n   215→        \"--config\",\n   216→        default=\"config/gates.json\",\n   217→        help=\"Path to gates configuration file (default: config/gates.json).\",\n   218→    )\n   219→    parser.add_argument(\n   220→        \"--quiet-ok\",\n   221→        action=\"store_true\",\n   222→        help=\"Suppress output when the check passes.\",\n   223→    )\n   224→    parser.add_argument(\n   225→        \"--verbose\",\n   226→        action=\"store_true\",\n   227→        help=\"Print skip diagnostics when the gate is disabled.\",\n   228→    )\n   229→    parser.add_argument(\n   230→        \"--fix\",\n   231→        action=\"store_true\",\n   232→        help=\"Normalize tasklist in place.\",\n   233→    )\n   234→    parser.add_argument(\n   235→        \"--dry-run\",\n   236→        action=\"store_true\",\n   237→        help=\"Show changes without modifying files (requires --fix).\",\n   238→    )\n   239→    return parser.parse_args(list(argv) if argv is not None else None)\n   240→\n   241→\n   242→def _tasklist_cache_path(root: Path) -> Path:\n   243→    return root / \".cache\" / \"tasklist.hash\"\n   244→\n   245→\n   246→def _tasklist_hash(text: str) -> str:\n   247→    return hashlib.sha256(text.encode(\"utf-8\")).hexdigest()\n   248→\n   249→\n   250→def _load_tasklist_cache(path: Path) -> dict:\n   251→    if not path.exists():\n   252→        return {}\n   253→    try:\n   254→        payload = json.loads(path.read_text(encoding=\"utf-8\"))\n   255→    except json.JSONDecodeError:\n   256→        return {}\n   257→    return payload if isinstance(payload, dict) else {}\n   258→\n   259→\n   260→def _write_tasklist_cache(\n   261→    path: Path,\n   262→    *,\n   263→    ticket: str,\n   264→    stage: str,\n   265→    hash_value: str,\n   266→    config_hash: str,\n   267→) -> None:\n   268→    path.parent.mkdir(parents=True, exist_ok=True)\n   269→    payload = {\n   270→        \"ticket\": ticket,\n   271→        \"stage\": stage,\n   272→        \"hash\": hash_value,\n   273→        \"config_hash\": config_hash,\n   274→        \"updated_at\": datetime.now(timezone.utc).isoformat(timespec=\"seconds\"),\n   275→    }\n   276→    path.write_text(json.dumps(payload, ensure_ascii=False, indent=2) + \"\\n\", encoding=\"utf-8\")\n   277→\n   278→\n   279→def _config_fingerprint(path: Path) -> str:\n   280→    if not path.exists():\n   281→        return \"missing\"\n   282→    try:\n   283→        data = path.read_bytes()\n   284→    except OSError:\n   285→        return \"error\"\n   286→    return hashlib.sha256(data).hexdigest()\n   287→\n   288→\n   289→def read_text(path: Path) -> str:\n   290→    return path.read_text(encoding=\"utf-8\")\n   291→\n   292→\n   293→def parse_front_matter(lines: List[str]) -> tuple[dict[str, str], int]:\n   294→    if not lines or lines[0].strip() != \"---\":\n   295→        return {}, 0\n   296→    end_idx = None\n   297→    for idx in range(1, len(lines)):\n   298→        if lines[idx].strip() == \"---\":\n   299→            end_idx = idx\n   300→            break\n   301→    if end_idx is None:\n   302→        return {}, 0\n   303→    front: dict[str, str] = {}\n   304→    for raw in lines[1:end_idx]:\n   305→        line = raw.strip()\n   306→        if not line or line.startswith(\"#\") or \":\" not in line:\n   307→            continue\n   308→        key, value = line.split(\":\", 1)\n   309→        front[key.strip()] = value.strip()\n   310→    return front, end_idx + 1\n   311→\n   312→\n   313→def parse_sections(lines: List[str]) -> tuple[List[Section], dict[str, List[Section]]]:\n   314→    sections: List[Section] = []\n   315→    for idx, line in enumerate(lines):\n   316→        match = SECTION_HEADER_RE.match(line)\n   317→        if not match:\n   318→            continue\n   319→        title = match.group(1).strip()\n   320→        if not title.startswith(\"AIDD:\"):\n   321→            continue\n   322→        if sections:\n   323→            sections[-1].end = idx\n   324→        sections.append(Section(title=title, start=idx, end=len(lines), lines=[]))\n   325→    for section in sections:\n   326→        section.lines = lines[section.start:section.end]\n   327→    mapped: dict[str, List[Section]] = {}\n   328→    for section in sections:\n   329→        mapped.setdefault(section.title, []).append(section)\n   330→    return sections, mapped\n   331→\n   332→\n   333→def section_body(section: Section | None) -> List[str]:\n   334→    if not section:\n   335→        return []\n   336→    return section.lines[1:]\n   337→\n   338→\n   339→def extract_field_value(lines: List[str], field: str) -> str | None:\n   340→    pattern = re.compile(rf\"^\\s*(?:[-*]\\s*)?{re.escape(field)}\\s*:\\s*(.*)$\", re.IGNORECASE)\n   341→    for line in lines:\n   342→        match = pattern.match(line)\n   343→        if match:\n   344→            return match.group(1).strip()\n   345→    return None\n   346→\n   347→\n   348→def block_has_heading(lines: List[str], heading: str) -> bool:\n   349→    pattern = re.compile(rf\"^\\s*-\\s*{re.escape(heading)}\\s*:\\s*(.*)$\", re.IGNORECASE)\n   350→    for line in lines:\n   351→        if pattern.match(line):\n   352→            return True\n   353→    return False\n   354→\n   355→\n   356→def is_placeholder(value: str) -> bool:\n   357→    stripped = value.strip()\n   358→    lowered = stripped.lower()\n   359→    if lowered in PLACEHOLDER_VALUES:\n   360→        return True\n   361→    return stripped.startswith(\"<\") and stripped.endswith(\">\")\n   362→\n   363→\n   364→def parse_inline_list(value: str) -> List[str]:\n   365→    raw = value.strip()\n   366→    if not raw:\n   367→        return []\n   368→    if raw.startswith(\"[\") and raw.endswith(\"]\"):\n   369→        raw = raw[1:-1].strip()\n   370→    if not raw:\n   371→        return []\n   372→    parts = raw.split(\",\") if \",\" in raw else raw.split()\n   373→    items = [part.strip() for part in parts if part.strip()]\n   374→    return [item for item in items if not is_placeholder(item)]\n   375→\n   376→\n   377→def extract_list_field(lines: List[str], field: str) -> List[str]:\n   378→    pattern = re.compile(rf\"^(?P<indent>\\s*)-\\s*{re.escape(field)}\\s*:\\s*$\", re.IGNORECASE)\n   379→    for idx, line in enumerate(lines):\n   380→        match = pattern.match(line)\n   381→        if not match:\n   382→            continue\n   383→        base_indent = len(match.group(\"indent\"))\n   384→        items: List[str] = []\n   385→        for raw in lines[idx + 1 :]:\n   386→            if not raw.strip():\n   387→                continue\n   388→            indent = len(raw) - len(raw.lstrip(\" \"))\n   389→            if indent <= base_indent and raw.lstrip().startswith(\"-\"):\n   390→                break\n   391→            if indent <= base_indent and raw.strip():\n   392→                break\n   393→            if raw.lstrip().startswith(\"-\") and indent > base_indent:\n   394→                item = raw.lstrip()[2:].strip()\n   395→                if item and not is_placeholder(item):\n   396→                    items.append(item)\n   397→        return items\n   398→    return []\n   399→\n   400→\n   401→def extract_mapping_field(lines: List[str], field: str) -> Dict[str, str]:\n   402→    pattern = re.compile(rf\"^(?P<indent>\\s*)-\\s*{re.escape(field)}\\s*:\\s*$\", re.IGNORECASE)\n   403→    for idx, line in enumerate(lines):\n   404→        match = pattern.match(line)\n   405→        if not match:\n   406→            continue\n   407→        base_indent = len(match.group(\"indent\"))\n   408→        result: Dict[str, str] = {}\n   409→        for raw in lines[idx + 1 :]:\n   410→            if not raw.strip():\n   411→                continue\n   412→            indent = len(raw) - len(raw.lstrip(\" \"))\n   413→            if indent <= base_indent and raw.lstrip().startswith(\"-\"):\n   414→                break\n   415→            if indent <= base_indent and raw.strip():\n   416→                break\n   417→            if raw.lstrip().startswith(\"-\") and indent > base_indent:\n   418→                item = raw.lstrip()[2:].strip()\n   419→                if \":\" in item:\n   420→                    key, value = item.split(\":\", 1)\n   421→                    key = key.strip()\n   422→                    value = value.strip()\n   423→                    if key and not is_placeholder(key) and not is_placeholder(value):\n   424→                        result[key] = value\n   425→        return result\n   426→    return {}\n   427→\n   428→\n   429→def normalize_dep_id(value: str) -> str:\n   430→    raw = value.strip()\n   431→    if not raw:\n   432→        return \"\"\n   433→    if \"iteration_id=\" in raw:\n   434→        return raw.split(\"iteration_id=\", 1)[1].strip()\n   435→    if \"id=\" in raw:\n   436→        return raw.split(\"id=\", 1)[1].strip()\n   437→    return raw\n   438→\n   439→\n   440→def parse_int(value: str | None) -> int | None:\n   441→    raw = str(value or \"\").strip()\n   442→    if not raw or is_placeholder(raw):\n   443→        return None\n   444→    try:\n   445→        return int(raw)\n   446→    except (TypeError, ValueError):\n   447→        return None\n   448→\n   449→\n   450→def split_checkbox_blocks(lines: List[str]) -> List[List[str]]:\n   451→    blocks: List[List[str]] = []\n   452→    current: List[str] = []\n   453→    for line in lines:\n   454→        if CHECKBOX_RE.match(line):\n   455→            if current:\n   456→                blocks.append(current)\n   457→                current = []\n   458→            current.append(line)\n   459→            continue\n   460→        if current:\n   461→            current.append(line)\n   462→    if current:\n   463→        blocks.append(current)\n   464→    return blocks\n   465→\n   466→\n   467→def extract_iteration_id(block: List[str]) -> str | None:\n   468→    for line in block:\n   469→        match = ITERATION_ID_RE.search(line)\n   470→        if match:\n   471→            return match.group(1).strip()\n   472→    header = block[0] if block else \"\"\n   473→    match = re.search(r\"\\bI\\d+\\b\", header)\n   474→    return match.group(0) if match else None\n   475→\n   476→\n   477→def extract_handoff_id(block: List[str]) -> str | None:\n   478→    for line in block:\n   479→        match = ID_RE.search(line)\n   480→        if match:\n   481→            return match.group(1).strip()\n   482→    return None\n   483→\n   484→\n   485→def normalize_source(value: str | None) -> str:\n   486→    normalized = (value or \"\").strip().lower()\n   487→    if normalized == \"reviewer\":\n   488→        return \"review\"\n   489→    return normalized\n   490→\n   491→\n   492→def parse_parenthetical_fields(header: str) -> dict[str, str]:\n   493→    fields: dict[str, str] = {}\n   494→    for group in re.findall(r\"\\(([^\\)]+)\\)\", header):\n   495→        if \":\" not in group:\n   496→            continue\n   497→        key, value = group.split(\":\", 1)\n   498→        key = key.strip().lower()\n   499→        fields[key] = value.strip()\n   500→    return fields\n   501→\n   502→\n   503→def split_iteration_blocks(lines: List[str]) -> List[List[str]]:\n   504→    blocks: List[List[str]] = []\n   505→    current: List[str] = []\n   506→    for line in lines:\n   507→        stripped = line.lstrip()\n   508→        if not stripped.startswith(\"-\"):\n   509→            if current:\n   510→                current.append(line)\n   511→            continue\n   512→        if line != stripped:\n   513→            if current:\n   514→                current.append(line)\n   515→            continue\n   516→        is_checkbox = bool(CHECKBOX_RE.match(line))\n   517→        has_iteration = bool(ITERATION_ID_RE.search(line)) or bool(re.match(r\"^-\\s*I\\d+\\b\", line))\n   518→        if is_checkbox or has_iteration:\n   519→            if current:\n   520→                blocks.append(current)\n   521→            current = [line]\n   522→            continue\n   523→        if current:\n   524→            current.append(line)\n   525→    if current:\n   526→        blocks.append(current)\n   527→    return blocks\n   528→\n   529→\n   530→def parse_iteration_items(section_lines: List[str]) -> List[IterationItem]:\n   531→    items: List[IterationItem] = []\n   532→    for block in split_iteration_blocks(section_lines):\n   533→        header = block[0].strip()\n   534→        checkbox_state = \"unknown\"\n   535→        checkbox_match = CHECKBOX_RE.match(header)\n   536→        if checkbox_match:\n   537→            checkbox_state = \"done\" if checkbox_match.group(\"state\").lower() == \"x\" else \"open\"\n   538→        fields = parse_parenthetical_fields(header)\n   539→        iteration_id = extract_iteration_id(block) or \"\"\n   540→        explicit_id = any(ITERATION_ID_RE.search(line) for line in block)\n   541→        parent_id = None\n   542→        for line in block:\n   543→            parent_match = PARENT_ITERATION_RE.search(line)\n   544→            if parent_match:\n   545→                parent_id = parent_match.group(1).strip()\n   546→                break\n   547→        state_value = extract_field_value(block, \"State\")\n   548→        state = (state_value or \"\").strip().lower()\n   549→        if not state:\n   550→            state = \"\"\n   551→        title = header\n   552→        if checkbox_match:\n   553→            title = checkbox_match.group(\"body\").strip()\n   554→        else:\n   555→            if title.startswith(\"-\"):\n   556→                title = title.lstrip(\"-\").strip()\n   557→        title = re.sub(r\"\\(iteration_id\\s*[:=].*?\\)\", \"\", title, flags=re.IGNORECASE).strip()\n   558→        if iteration_id:\n   559→            title = re.sub(rf\"^{re.escape(iteration_id)}\\s*[:\\-]\\s*\", \"\", title, flags=re.IGNORECASE).strip()\n   560→        priority = (fields.get(\"priority\") or extract_field_value(block, \"Priority\") or \"\").strip().lower()\n   561→        blocking_raw = (fields.get(\"blocking\") or extract_field_value(block, \"Blocking\") or \"\").strip().lower()\n   562→        blocking = blocking_raw == \"true\"\n   563→        deps = parse_inline_list(extract_field_value(block, \"deps\") or \"\")\n   564→        if not deps:\n   565→            deps = extract_list_field(block, \"deps\")\n   566→        locks = parse_inline_list(extract_field_value(block, \"locks\") or \"\")\n   567→        if not locks:\n   568→            locks = extract_list_field(block, \"locks\")\n   569→        deps = [normalize_dep_id(dep) for dep in deps if dep]\n   570→        items.append(\n   571→            IterationItem(\n   572→                item_id=iteration_id,\n   573→                title=title,\n   574→                state=state,\n   575→                checkbox=checkbox_state,\n   576→                parent_id=parent_id,\n   577→                explicit_id=explicit_id,\n   578→                priority=priority,\n   579→                blocking=blocking,\n   580→                deps=deps,\n   581→                locks=locks,\n   582→                lines=block,\n   583→            )\n   584→        )\n   585→    return items\n   586→\n   587→\n   588→def parse_handoff_items(section_lines: List[str]) -> List[HandoffItem]:\n   589→    parsed: List[HandoffItem] = []\n   590→    for block in split_checkbox_blocks(section_lines):\n   591→        header = block[0]\n   592→        checkbox_state = \"unknown\"\n   593→        match = CHECKBOX_RE.match(header)\n   594→        if match:\n   595→            checkbox_state = \"done\" if match.group(\"state\").lower() == \"x\" else \"open\"\n   596→        title = match.group(\"body\").strip() if match else header.strip()\n   597→        title = re.sub(r\"\\([^\\)]*\\)\", \"\", title).strip()\n   598→        fields = parse_parenthetical_fields(header)\n   599→        item_id = fields.get(\"id\") or extract_handoff_id(block) or \"\"\n   600→        priority = (fields.get(\"priority\") or extract_field_value(block, \"Priority\") or \"\").strip().lower()\n   601→        blocking_raw = (fields.get(\"blocking\") or extract_field_value(block, \"Blocking\") or \"\").strip().lower()\n   602→        blocking = blocking_raw == \"true\"\n   603→        source = normalize_source(extract_field_value(block, \"source\") or fields.get(\"source\"))\n   604→        status = (extract_field_value(block, \"Status\") or \"\").strip().lower()\n   605→        if not status and checkbox_state in {\"open\", \"done\"}:\n   606→            status = checkbox_state\n   607→        parsed.append(\n   608→            HandoffItem(\n   609→                item_id=item_id,\n   610→                title=title,\n   611→                status=status,\n   612→                checkbox=checkbox_state,\n   613→                priority=priority,\n   614→                blocking=blocking,\n   615→                source=source,\n   616→                lines=block,\n   617→            )\n   618→        )\n   619→    return parsed\n   620→\n   621→\n   622→def parse_next3_items(section_lines: List[str]) -> List[List[str]]:\n   623→    return split_checkbox_blocks(section_lines)\n   624→\n   625→\n   626→def extract_ref_id(block: List[str]) -> tuple[str, str | None, bool]:\n   627→    ref_value = None\n   628→    for line in block:\n   629→        match = REF_RE.search(line)\n   630→        if match:\n   631→            ref_value = match.group(1).strip()\n   632→            break\n   633→    if ref_value:\n   634→        if \"iteration_id=\" in ref_value:\n   635→            return \"iteration\", ref_value.split(\"iteration_id=\", 1)[1].strip(), True\n   636→        if \"id=\" in ref_value:\n   637→            return \"handoff\", ref_value.split(\"id=\", 1)[1].strip(), True\n   638→    for line in block:\n   639→        match = ITERATION_ID_RE.search(line)\n   640→        if match:\n   641→            return \"iteration\", match.group(1).strip(), False\n   642→        match = ID_RE.search(line)\n   643→        if match:\n   644→            return \"handoff\", match.group(1).strip(), False\n   645→    return \"\", None, False\n   646→\n   647→\n   648→def progress_entries_from_lines(lines: List[str]) -> tuple[List[dict], List[str]]:\n   649→    entries: List[dict] = []\n   650→    invalid: List[str] = []\n   651→    for raw in lines:\n   652→        if not raw.strip().startswith(\"-\"):\n   653→            continue\n   654→        stripped = raw.strip().lower()\n   655→        if stripped.startswith(\"- (empty)\") or stripped.startswith(\"- ...\"):\n   656→            continue\n   657→        match = PROGRESS_LINE_RE.match(raw)\n   658→        if not match:\n   659→            invalid.append(raw)\n   660→            continue\n   661→        info = match.groupdict()\n   662→        info[\"source\"] = info[\"source\"].lower()\n   663→        info[\"kind\"] = info[\"kind\"].lower()\n   664→        info[\"msg\"] = info[\"msg\"].strip()\n   665→        entries.append(info)\n   666→    return entries, invalid\n   667→\n   668→\n   669→def dedupe_progress(entries: List[dict]) -> List[dict]:\n   670→    seen = set()\n   671→    deduped: List[dict] = []\n   672→    for entry in entries:\n   673→        key = (entry.get(\"date\"), entry.get(\"source\"), entry.get(\"item_id\"), entry.get(\"hash\"))\n   674→        if key in seen:\n   675→            continue\n   676→        seen.add(key)\n   677→        deduped.append(entry)\n   678→    return deduped\n   679→\n   680→\n   681→def progress_entry_line(entry: dict) -> str:\n   682→    parts = [\n   683→        f\"- {entry['date']}\",\n   684→        f\"source={entry['source']}\",\n   685→        f\"id={entry['item_id']}\",\n   686→        f\"kind={entry['kind']}\",\n   687→        f\"hash={entry['hash']}\",\n   688→    ]\n   689→    if entry.get(\"link\"):\n   690→        parts.append(f\"link={entry['link']}\")\n   691→    msg = entry.get(\"msg\") or \"\"\n   692→    if len(msg) > 200:\n   693→        msg = msg[:197] + \"...\"\n   694→    parts.append(f\"msg={msg}\")\n   695→    line = \" \".join(parts)\n   696→    if len(line) > 240:\n   697→        line = line[:237] + \"...\"\n   698→    return line\n   699→\n   700→\n   701→def load_gate_config(path: Path) -> dict | None:\n   702→    if not path.is_file():\n   703→        return None\n   704→    try:\n   705→        data = gates.load_gates_config(path)\n   706→    except ValueError:\n   707→        return None\n   708→    if \"tasklist_spec\" not in data:\n   709→        return None\n   710→    section = data.get(\"tasklist_spec\")\n   711→    if isinstance(section, bool):\n   712→        return {\"enabled\": section}\n   713→    return section if isinstance(section, dict) else None\n   714→\n   715→\n   716→def should_skip_gate(gate: dict | None, branch: str) -> tuple[bool, str]:\n   717→    if gate is None:\n   718→        return True, \"gate config missing\"\n   719→    enabled = bool(gate.get(\"enabled\", True))\n   720→    if not enabled:\n   721→        return True, \"gate disabled\"\n   722→    if branch and gates.matches(gate.get(\"skip_branches\"), branch):\n   723→        return True, \"branch skipped\"\n   724→    branches = gate.get(\"branches\")\n   725→    if branch and branches and not gates.matches(branches, branch):\n   726→        return True, \"branch not in allowlist\"\n   727→    return False, \"\"\n   728→\n   729→\n   730→def severity_for_stage(stage: str, *, strict: bool = False) -> str:\n   731→    normalized = (stage or \"\").strip().lower()\n   732→    if strict or normalized in STRICT_STAGES:\n   733→        return \"error\"\n   734→    return \"warn\"\n   735→\n   736→\n   737→def resolve_stage(root: Path, context_pack: List[str]) -> str:\n   738→    value = runtime.read_active_stage(root)\n   739→    if value:\n   740→        return value.lower()\n   741→    stage_value = extract_field_value(context_pack, \"Stage\")\n   742→    return (stage_value or \"\").strip().lower()\n   743→\n   744→\n   745→def parse_plan_iteration_ids(root: Path, plan_path: Path) -> list[str]:\n   746→    try:\n   747→        text = plan_path.read_text(encoding=\"utf-8\")\n   748→    except OSError:\n   749→        return []\n   750→    lines = text.splitlines()\n   751→    _, sections = parse_sections(lines)\n   752→    plan_section = sections.get(\"AIDD:ITERATIONS\")\n   753→    if not plan_section:\n   754→        return []\n   755→    ids: list[str] = []\n   756→    for line in section_body(plan_section[0]):\n   757→        match = ITERATION_ID_RE.search(line)\n   758→        if match:\n   759→            ids.append(match.group(1).strip())\n   760→    return ids\n   761→\n   762→\n   763→def pick_open_state(checkbox_state: str, state_value: str) -> tuple[Optional[bool], str]:\n   764→    state = (state_value or \"\").strip().lower()\n   765→    if state and state not in ITERATION_STATE_VALUES:\n   766→        return None, state\n   767→    if checkbox_state == \"done\" or state == \"done\":\n   768→        return False, state\n   769→    if checkbox_state == \"open\" or state in {\"open\", \"blocked\"}:\n   770→        return True, state\n   771→    return None, state\n   772→\n   773→\n   774→def handoff_open_state(checkbox_state: str, status: str) -> tuple[Optional[bool], str]:\n   775→    status_value = (status or \"\").strip().lower()\n   776→    if status_value and status_value not in HANDOFF_STATUS_VALUES:\n   777→        return None, status_value\n   778→    if checkbox_state == \"done\" or status_value == \"done\":\n   779→        return False, status_value\n   780→    if checkbox_state == \"open\" or status_value in {\"open\", \"blocked\"}:\n   781→        return True, status_value\n   782→    return None, status_value\n   783→\n   784→\n   785→def next3_placeholder_present(lines: List[str]) -> bool:\n   786→    for line in lines:\n   787→        stripped = line.strip().lower()\n   788→        if stripped.startswith(\"- (none)\") or \"no pending\" in stripped:\n   789→            return True\n   790→    return False\n   791→\n   792→\n   793→def extract_bullets(lines: List[str]) -> int:\n   794→    count = 0\n   795→    for line in lines:\n   796→        if re.match(r\"^\\s*-\\s+\", line):\n   797→            count += 1\n   798→    return count\n   799→\n   800→\n   801→def subsection_lines(section_lines: List[str], heading: str) -> List[str]:\n   802→    start = None\n   803→    for idx, line in enumerate(section_lines):\n   804→        if line.strip().lower() == heading.lower():\n   805→            start = idx + 1\n   806→            break\n   807→    if start is None:\n   808→        return []\n   809→    end = len(section_lines)\n   810→    for idx in range(start, len(section_lines)):\n   811→        if section_lines[idx].strip().startswith(\"### \"):\n   812→            end = idx\n   813→            break\n   814→    return section_lines[start:end]\n   815→\n   816→\n   817→def collect_stacktrace_flags(lines: List[str]) -> bool:\n   818→    at_count = 0\n   819→    caused_count = 0\n   820→    in_fence = False\n   821→    fence_count = 0\n   822→    for line in lines:\n   823→        stripped = line.rstrip()\n   824→        if stripped.startswith(\"```\"):\n   825→            in_fence = not in_fence\n   826→            if not in_fence:\n   827→                if fence_count > 20:\n   828→                    return True\n   829→                fence_count = 0\n   830→            continue\n   831→        if in_fence:\n   832→            fence_count += 1\n   833→            continue\n   834→        if re.match(r\"^\\s+at\\s+\", stripped):\n   835→            at_count += 1\n   836→            if at_count >= 5:\n   837→                return True\n   838→        else:\n   839→            at_count = 0\n   840→        if stripped.startswith(\"Caused by:\"):\n   841→            caused_count += 1\n   842→            if caused_count >= 2:\n   843→                return True\n   844→        else:\n   845→            caused_count = 0\n   846→    return False\n   847→\n   848→\n   849→def large_code_fence_without_report(lines: List[str]) -> bool:\n   850→    in_fence = False\n   851→    fence_lines: List[int] = []\n   852→    start_idx = 0\n   853→    for idx, line in enumerate(lines):\n   854→        if line.strip().startswith(\"```\"):\n   855→            if not in_fence:\n   856→                in_fence = True\n   857→                fence_lines = []\n   858→                start_idx = idx\n   859→            else:\n   860→                in_fence = False\n   861→                if len(fence_lines) > 20 and not find_report_link_near(lines, start_idx):\n   862→                    return True\n   863→            continue\n   864→        if in_fence:\n   865→            fence_lines.append(idx)\n   866→    return False\n   867→\n   868→\n   869→def find_report_link_near(lines: List[str], idx: int, window: int = 5) -> bool:\n   870→    start = max(0, idx - window)\n   871→    end = min(len(lines), idx + window + 1)\n   872→    for line in lines[start:end]:\n   873→        if \"aidd/reports/\" in line:\n   874→            return True\n   875→    return False\n   876→\n   877→\n   878→def parse_qa_traceability(section_lines: List[str]) -> dict[str, dict]:\n   879→    result: dict[str, dict] = {}\n   880→    for line in section_lines:\n   881→        match = re.search(r\"\\bAC-([A-Za-z0-9_-]+)\\b\", line)\n   882→        if not match:\n   883→            continue\n   884→        ac_id = match.group(1)\n   885→        status_match = re.search(r\"\\b(not[- ]met|not[- ]verified|met)\\b\", line, re.IGNORECASE)\n   886→        status = status_match.group(1).lower() if status_match else \"\"\n   887→        status = status.replace(\" \", \"-\")\n   888→        evidence = \"\"\n   889→        if \"→\" in line:\n   890→            parts = [part.strip() for part in line.split(\"→\")]\n   891→            if len(parts) >= 4:\n   892→                evidence = parts[-1]\n   893→        result.setdefault(ac_id, {\"status\": status, \"evidence\": []})\n   894→        if status:\n   895→            current = result[ac_id][\"status\"]\n   896→            order = {\"met\": 0, \"not-verified\": 1, \"not-met\": 2}\n   897→            if current in order and status in order:\n   898→                if order[status] > order[current]:\n   899→                    result[ac_id][\"status\"] = status\n   900→            else:\n   901→                result[ac_id][\"status\"] = status\n   902→        if evidence:\n   903→            result[ac_id][\"evidence\"].append(evidence)\n   904→    return result\n   905→\n   906→\n   907→def resolve_plan_path(root: Path, front: dict[str, str], ticket: str) -> Path:\n   908→    plan = front.get(\"Plan\") or front.get(\"plan\") or \"\"\n   909→    if plan:\n   910→        raw = Path(plan)\n   911→        if not raw.is_absolute():\n   912→            if raw.parts and raw.parts[0] == \"aidd\" and root.name == \"aidd\":\n   913→                return root / Path(*raw.parts[1:])\n   914→            return root / raw\n   915→        return raw\n   916→    return root / \"docs\" / \"plan\" / f\"{ticket}.md\"\n   917→\n   918→\n   919→def resolve_prd_path(root: Path, front: dict[str, str], ticket: str) -> Path:\n   920→    prd = front.get(\"PRD\") or front.get(\"prd\") or \"\"\n   921→    if prd:\n   922→        raw = Path(prd)\n   923→        if not raw.is_absolute():\n   924→            if raw.parts and raw.parts[0] == \"aidd\" and root.name == \"aidd\":\n   925→                return root / Path(*raw.parts[1:])\n   926→            return root / raw\n   927→        return raw\n   928→    return root / \"docs\" / \"prd\" / f\"{ticket}.prd.md\"\n   929→\n   930→\n   931→def resolve_spec_path(root: Path, front: dict[str, str], ticket: str) -> Path | None:\n   932→    spec = front.get(\"Spec\") or front.get(\"spec\") or \"\"\n   933→    if spec:\n   934→        lowered = spec.strip().lower()\n   935→        if is_placeholder(spec) or lowered in SPEC_PLACEHOLDERS:\n   936→            return None\n   937→        raw = Path(spec)\n   938→        if not raw.is_absolute():\n   939→            if raw.parts and raw.parts[0] == \"aidd\" and root.name == \"aidd\":\n   940→                return root / Path(*raw.parts[1:])\n   941→            return root / raw\n   942→        return raw\n   943→    return root / \"docs\" / \"spec\" / f\"{ticket}.spec.yaml\"\n   944→\n   945→\n   946→def rel_path(root: Path, path: Path) -> str:\n   947→    try:\n   948→        return path.relative_to(root).as_posix()\n   949→    except ValueError:\n   950→        return str(path)\n   951→\n   952→\n   953→def extract_section_text(text: str, titles: Iterable[str]) -> str:\n   954→    lines = text.splitlines()\n   955→    _, section_map = parse_sections(lines)\n   956→    collected: List[str] = []\n   957→    for title in titles:\n   958→        for section in section_map.get(title, []):\n   959→            collected.extend(section_body(section))\n   960→    return \"\\n\".join(collected) if collected else text\n   961→\n   962→\n   963→def mentions_spec_required(text: str) -> bool:\n   964→    if not text:\n   965→        return False\n   966→    return any(pattern.search(text) for pattern in SPEC_REQUIRED_PATTERNS)\n   967→\n   968→\n   969→def tasklist_path_for(root: Path, ticket: str) -> Path:\n   970→    return root / \"docs\" / \"tasklist\" / f\"{ticket}.md\"\n   971→\n   972→\n   973→def progress_archive_path(root: Path, ticket: str) -> Path:\n   974→    return root / \"reports\" / \"progress\" / f\"{ticket}.log\"\n   975→\n   976→\n   977→def deps_satisfied(\n   978→    deps: List[str],\n   979→    iteration_map: dict[str, IterationItem],\n   980→    handoff_map: dict[str, HandoffItem],\n   981→) -> bool:\n   982→    from aidd_runtime import tasklist_normalize as _tasklist_normalize\n   983→\n   984→    return _tasklist_normalize.deps_satisfied(deps, iteration_map, handoff_map)\n   985→\n   986→\n   987→def unmet_deps(\n   988→    deps: List[str],\n   989→    iteration_map: dict[str, IterationItem],\n   990→    handoff_map: dict[str, HandoffItem],\n   991→) -> List[str]:\n   992→    from aidd_runtime import tasklist_normalize as _tasklist_normalize\n   993→\n   994→    return _tasklist_normalize.unmet_deps(deps, iteration_map, handoff_map)\n   995→\n   996→\n   997→def build_open_items(\n   998→    iterations: List[IterationItem],\n   999→    handoff_items: List[HandoffItem],\n  1000→    plan_order: List[str],\n  1001→) -> tuple[List[WorkItem], dict[str, IterationItem], dict[str, HandoffItem]]:\n  1002→    from aidd_runtime import tasklist_normalize as _tasklist_normalize\n  1003→\n  1004→    return _tasklist_normalize.build_open_items(iterations, handoff_items, plan_order)\n  1005→\n  1006→\n  1007→def build_next3_lines(open_items: List[WorkItem], preamble: List[str] | None = None) -> List[str]:\n  1008→    from aidd_runtime import tasklist_normalize as _tasklist_normalize\n  1009→\n  1010→    return _tasklist_normalize.build_next3_lines(open_items, preamble)\n  1011→\n  1012→\n  1013→def normalize_progress_section(\n  1014→    lines: List[str],\n  1015→    ticket: str,\n  1016→    root: Path,\n  1017→    summary: List[str],\n  1018→    *,\n  1019→    dry_run: bool,\n  1020→) -> List[str]:\n  1021→    from aidd_runtime import tasklist_normalize as _tasklist_normalize\n  1022→\n  1023→    return _tasklist_normalize.normalize_progress_section(lines, ticket, root, summary, dry_run=dry_run)\n  1024→\n  1025→\n  1026→def normalize_qa_traceability(lines: List[str], summary: List[str]) -> List[str]:\n  1027→    from aidd_runtime import tasklist_normalize as _tasklist_normalize\n  1028→\n  1029→    return _tasklist_normalize.normalize_qa_traceability(lines, summary)\n  1030→\n  1031→\n  1032→def normalize_handoff_section(sections: List[Section], summary: List[str]) -> List[str]:\n  1033→    from aidd_runtime import tasklist_normalize as _tasklist_normalize\n  1034→\n  1035→    return _tasklist_normalize.normalize_handoff_section(sections, summary)\n  1036→\n  1037→\n  1038→def normalize_tasklist(\n  1039→    root: Path,\n  1040→    ticket: str,\n  1041→    text: str,\n  1042→    *,\n  1043→    dry_run: bool = False,\n  1044→) -> NormalizeResult:\n  1045→    from aidd_runtime import tasklist_normalize as _tasklist_normalize\n  1046→\n  1047→    return _tasklist_normalize.normalize_tasklist(root, ticket, text, dry_run=dry_run)\n  1048→\n  1049→\n  1050→def check_tasklist_text(\n  1051→    root: Path,\n  1052→    ticket: str,\n  1053→    text: str,\n  1054→    *,\n  1055→    normalize_fix_mode: bool = False,\n  1056→) -> TasklistCheckResult:\n  1057→    from aidd_runtime import tasklist_validate as _tasklist_validate\n  1058→\n  1059→    return _tasklist_validate.check_tasklist_text(\n  1060→        root,\n  1061→        ticket,\n  1062→        text,\n  1063→        normalize_fix_mode=normalize_fix_mode,\n  1064→    )\n  1065→\n  1066→def check_tasklist(\n  1067→    root: Path,\n  1068→    ticket: str,\n  1069→    *,\n  1070→    normalize_fix_mode: bool = False,\n  1071→) -> TasklistCheckResult:\n  1072→    tasklist_path = tasklist_path_for(root, ticket)\n  1073→    if not tasklist_path.exists():\n  1074→        return TasklistCheckResult(status=\"error\", message=f\"tasklist not found: {tasklist_path}\")\n  1075→    text = read_text(tasklist_path)\n  1076→    return check_tasklist_text(root, ticket, text, normalize_fix_mode=normalize_fix_mode)\n  1077→\n  1078→\n  1079→def run_check(args: argparse.Namespace) -> int:\n  1080→    root = resolve_aidd_root(Path.cwd())\n  1081→    config_path = Path(args.config)\n  1082→    if not config_path.is_absolute():\n  1083→        config_path = root / config_path\n  1084→\n  1085→    if args.fix and args.dry_run:\n  1086→        pass\n  1087→\n  1088→    if not args.fix:\n  1089→        gate = load_gate_config(config_path)\n  1090→        skip_gate, skip_reason = should_skip_gate(gate, args.branch or \"\")\n  1091→        if skip_gate:\n  1092→            if args.verbose:\n  1093→                print(f\"[tasklist-check] SKIP: {skip_reason}\", file=sys.stderr)\n  1094→            return 0\n  1095→\n  1096→    identifiers = resolve_identifiers(root, ticket=args.ticket, slug_hint=args.slug_hint)\n  1097→    ticket = (identifiers.resolved_ticket or \"\").strip()\n  1098→    if not ticket:\n  1099→        result = TasklistCheckResult(status=\"error\", message=\"ticket not provided and docs/.active.json missing\")\n  1100→    else:\n  1101→        tasklist_path = tasklist_path_for(root, ticket)\n  1102→        if not tasklist_path.exists():\n  1103→            result = TasklistCheckResult(status=\"error\", message=f\"tasklist not found: {tasklist_path}\")\n  1104→        else:\n  1105→            tasklist_text = tasklist_path.read_text(encoding=\"utf-8\")\n  1106→            stage_value = runtime.read_active_stage(root)\n  1107→            cache_path = _tasklist_cache_path(root)\n  1108→            current_hash = _tasklist_hash(tasklist_text)\n  1109→            config_hash = _config_fingerprint(config_path)\n  1110→\n  1111→            if not args.fix and not args.dry_run:\n  1112→                cache_payload = _load_tasklist_cache(cache_path)\n  1113→                if (\n  1114→                    cache_payload.get(\"ticket\") == ticket\n  1115→                    and cache_payload.get(\"stage\") == stage_value\n  1116→                    and cache_payload.get(\"hash\") == current_hash\n  1117→                    and cache_payload.get(\"config_hash\") == config_hash\n  1118→                ):\n  1119→                    if not args.quiet_ok:\n  1120→                        print(\"[tasklist-check] SKIP: cache hit (reason_code=cache_hit)\", file=sys.stderr)\n  1121→                    return 0\n  1122→\n  1123→            if args.fix:\n  1124→                original = tasklist_text\n  1125→                normalized = normalize_tasklist(root, ticket, original, dry_run=args.dry_run)\n  1126→                if args.dry_run:\n  1127→                    diff = difflib.unified_diff(\n  1128→                        original.splitlines(),\n  1129→                        normalized.updated_text.splitlines(),\n  1130→                        fromfile=str(tasklist_path),\n  1131→                        tofile=str(tasklist_path),\n  1132→                        lineterm=\"\",\n  1133→                    )\n  1134→                    for line in diff:\n  1135→                        print(line)\n  1136→                    for line in normalized.summary:\n  1137→                        print(f\"[tasklist-check] {line}\")\n  1138→                    return 0\n  1139→                if normalized.changed:\n  1140→                    backup_dir = root / \"reports\" / \"tasklist_backups\" / ticket\n  1141→                    backup_dir.mkdir(parents=True, exist_ok=True)\n  1142→                    timestamp = datetime.now(timezone.utc).strftime(\"%Y%m%d%H%M%S\")\n  1143→                    backup_path = backup_dir / f\"{timestamp}.md\"\n  1144→                    backup_path.write_text(original, encoding=\"utf-8\")\n  1145→                    tasklist_path.write_text(normalized.updated_text, encoding=\"utf-8\")\n  1146→                    for line in normalized.summary:\n  1147→                        print(f\"[tasklist-check] {line}\")\n  1148→                    print(f\"[tasklist-check] backup saved: {backup_path}\")\n  1149→                result = check_tasklist(root, ticket, normalize_fix_mode=True)\n  1150→            else:\n  1151→                result = check_tasklist_text(root, ticket, tasklist_text)\n  1152→\n  1153→            if result.status in {\"ok\", \"warn\"}:\n  1154→                updated_text = tasklist_path.read_text(encoding=\"utf-8\")\n  1155→                updated_hash = _tasklist_hash(updated_text)\n  1156→                _write_tasklist_cache(\n  1157→                    cache_path,\n  1158→                    ticket=ticket,\n  1159→                    stage=stage_value,\n  1160→                    hash_value=updated_hash,\n  1161→                    config_hash=config_hash,\n  1162→                )\n  1163→            if result.status == \"error\":\n  1164→                if result.details:\n  1165→                    for entry in result.details:\n  1166→                        print(f\"[tasklist-check] {entry}\", file=sys.stderr)\n  1167→                print(f\"[tasklist-check] FAIL: {result.message}\", file=sys.stderr)\n  1168→                return result.exit_code()\n  1169→            if result.status == \"warn\":\n  1170→                if result.details:\n  1171→                    for entry in result.details:\n  1172→                        print(f\"[tasklist-check] WARN: {entry}\", file=sys.stderr)\n  1173→            return result.exit_code()\n  1174→    if result.status == \"error\":\n  1175→        if result.details:\n  1176→            for entry in result.details:\n  1177→                print(f\"[tasklist-check] {entry}\", file=sys.stderr)\n  1178→        print(f\"[tasklist-check] FAIL: {result.message}\", file=sys.stderr)\n  1179→        return result.exit_code()\n  1180→\n  1181→    if result.status == \"warn\":\n  1182→        if result.details:\n  1183→            for entry in result.details:\n  1184→                print(f\"[tasklist-check] WARN: {entry}\", file=sys.stderr)\n  1185→        return result.exit_code()\n  1186→\n  1187→    if result.status == \"ok\" and not args.quiet_ok:\n  1188→        print(\"[tasklist-check] OK: tasklist READY\", file=sys.stderr)\n  1189→    return result.exit_code()\n  1190→\n  1191→\n  1192→def main(argv: Iterable[str] | None = None) -> int:\n  1193→    args = parse_args(argv)\n  1194→    return run_check(args)\n  1195→\n  1196→\n  1197→if __name__ == \"__main__\":  # pragma: no cover\n  1198→    raise SystemExit(main())\n  1199→\n\n<system-reminder>\nWhenever you read a file, you should consider whether it would be considered malware. You CAN and SHOULD provide analysis of malware, what it is doing. But you MUST refuse to improve or augment the code. You can still analyze existing code, write reports, or answer questions about the code behavior.\n</system-reminder>\n"}]},"parent_tool_use_id":null,"session_id":"3bb52f18-577c-4498-9d63-c3d743a62879","uuid":"711615c7-0e58-4913-82a5-a3d70927c1c2","tool_use_result":{"type":"text","file":{"filePath":"/Users/griogrii_riabov/.claude/plugins/cache/aidd-local/feature-dev-aidd/0.1.0/skills/aidd-flow-state/runtime/tasklist_check_parts/core.py","content":"#!/usr/bin/env python3\n\"\"\"Validate and normalize tasklists.\"\"\"\n\nfrom __future__ import annotations\n\nimport argparse\nimport hashlib\nimport difflib\nimport json\nimport re\nimport sys\nfrom dataclasses import dataclass\nfrom datetime import datetime, timezone\nfrom pathlib import Path\nfrom typing import Iterable, List, Optional\n\nimport os\nimport sys\nfrom pathlib import Path\n\n\ndef _ensure_plugin_root_on_path() -> None:\n    env_root = os.environ.get(\"CLAUDE_PLUGIN_ROOT\", \"\").strip()\n    if env_root:\n        root = Path(env_root).resolve()\n        if (root / \"aidd_runtime\").is_dir():\n            if str(root) not in sys.path:\n                sys.path.insert(0, str(root))\n            return\n\n    probe = Path(__file__).resolve()\n    for parent in (probe.parent, *probe.parents):\n        if (parent / \"aidd_runtime\").is_dir():\n            os.environ.setdefault(\"CLAUDE_PLUGIN_ROOT\", str(parent))\n            if str(parent) not in sys.path:\n                sys.path.insert(0, str(parent))\n            return\n\n\n_ensure_plugin_root_on_path()\n\nfrom aidd_runtime import gates\nfrom aidd_runtime import runtime\nfrom aidd_runtime.feature_ids import resolve_aidd_root, resolve_identifiers\n\n\nPLACEHOLDER_VALUES = {\"\", \"...\", \"<...>\", \"tbd\", \"<tbd>\", \"todo\", \"<todo>\"}\nNONE_VALUES = {\"none\", \"нет\", \"n/a\", \"na\"}\nSPEC_PLACEHOLDERS = {\"none\", \"нет\", \"n/a\", \"na\", \"-\", \"missing\"}\nSPEC_REQUIRED_PATTERNS = [\n    re.compile(pattern, re.IGNORECASE)\n    for pattern in (\n        r\"\\bui\\b\",\n        r\"\\bux\\b\",\n        r\"\\bui/ux\\b\",\n        r\"\\bfrontend\\b\",\n        r\"\\bfront[- ]end\\b\",\n        r\"/ui/\",\n        r\"/ux/\",\n        r\"/frontend/\",\n        r\"/front-end/\",\n        r\"\\bweb\\b\",\n        r\"\\bинтерфейс\",\n        r\"\\bэкран\",\n        r\"\\bстраниц\",\n        r\"\\bформа\\b\",\n        r\"\\bдизайн\\b\",\n        r\"\\bвизуал\",\n        r\"\\bмакет\",\n        r\"\\blayout\\b\",\n        r\"\\bapi\\b\",\n        r\"\\bendpoint\\b\",\n        r\"\\brest\\b\",\n        r\"\\bgrpc\\b\",\n        r\"\\bgraphql\\b\",\n        r\"\\bcontract\\b\",\n        r\"\\bschema\\b\",\n        r\"\\bmigration\\b\",\n        r\"\\bdb\\b\",\n        r\"\\bdatabase\\b\",\n        r\"\\bdata\\b\",\n        r\"\\btable\\b\",\n        r\"\\bcolumn\\b\",\n        r\"\\bконтракт\\b\",\n        r\"\\bсхем\",\n        r\"\\bмиграц\",\n        r\"\\bбаз\",\n        r\"\\bданн\",\n        r\"\\bтаблиц\",\n        r\"\\bколонк\",\n        r\"\\be2e\\b\",\n        r\"\\bend[- ]to[- ]end\\b\",\n        r\"\\bstaging\\b\",\n        r\"\\bstand\\b\",\n        r\"\\bстенд\\b\",\n    )\n]\n\nREQUIRED_SECTIONS = {\n    \"AIDD:CONTEXT_PACK\",\n    \"AIDD:SPEC_PACK\",\n    \"AIDD:TEST_STRATEGY\",\n    \"AIDD:TEST_EXECUTION\",\n    \"AIDD:ITERATIONS_FULL\",\n    \"AIDD:NEXT_3\",\n    \"AIDD:HANDOFF_INBOX\",\n    \"AIDD:QA_TRACEABILITY\",\n    \"AIDD:CHECKLIST\",\n    \"AIDD:PROGRESS_LOG\",\n    \"AIDD:HOW_TO_UPDATE\",\n}\n\nPRIORITY_ORDER = {\"critical\": 0, \"high\": 1, \"medium\": 2, \"low\": 3}\nPRIORITY_VALUES = set(PRIORITY_ORDER)\nHANDOFF_STATUS_VALUES = {\"open\", \"done\", \"blocked\"}\nHANDOFF_SOURCE_VALUES = {\"research\", \"review\", \"qa\", \"manual\"}\nITERATION_STATE_VALUES = {\"open\", \"done\", \"blocked\"}\nPROGRESS_SOURCES = {\"implement\", \"review\", \"qa\", \"research\", \"normalize\"}\nPROGRESS_KINDS = {\"iteration\", \"handoff\"}\nSTRICT_STAGES = {\"review\", \"qa\"}\n\nSECTION_HEADER_RE = re.compile(r\"^##\\s+(.+?)\\s*$\")\nCHECKBOX_RE = re.compile(r\"^\\s*-\\s*\\[(?P<state>[ xX])\\]\\s+(?P<body>.+)$\")\nREF_RE = re.compile(r\"\\bref\\s*:\\s*([^\\)]+)\")\nID_RE = re.compile(r\"\\bid\\s*:\\s*([A-Za-z0-9_.:-]+)\")\nITERATION_ID_RE = re.compile(r\"\\biteration_id\\s*[:=]\\s*([A-Za-z0-9_.:-]+)\")\nSTATE_RE = re.compile(r\"\\bstate\\s*:\\s*([A-Za-z0-9_-]+)\", re.IGNORECASE)\nPARENT_ITERATION_RE = re.compile(r\"\\bparent_iteration_id\\s*:\\s*([A-Za-z0-9_.:-]+)\", re.IGNORECASE)\nPROGRESS_LINE_RE = re.compile(\n    r\"^\\s*-\\s*(?P<date>\\d{4}-\\d{2}-\\d{2})\\s+\"\n    r\"source=(?P<source>[A-Za-z0-9_-]+)\\s+\"\n    r\"id=(?P<item_id>[A-Za-z0-9_.:-]+)\\s+\"\n    r\"kind=(?P<kind>[A-Za-z0-9_-]+)\\s+\"\n    r\"hash=(?P<hash>[A-Za-z0-9]+)\"\n    r\"(?:\\s+link=(?P<link>\\S+))?\\s+\"\n    r\"msg=(?P<msg>.+)$\"\n)\n\n\n@dataclass\nclass Section:\n    title: str\n    start: int\n    end: int\n    lines: List[str]\n\n\n@dataclass\nclass Issue:\n    severity: str\n    message: str\n\n\n@dataclass\nclass TasklistCheckResult:\n    status: str\n    message: str = \"\"\n    details: List[str] | None = None\n    warnings: List[str] | None = None\n\n    def exit_code(self) -> int:\n        return 0 if self.status in {\"ok\", \"warn\", \"skip\"} else 2\n\n\n@dataclass\nclass IterationItem:\n    item_id: str\n    title: str\n    state: str\n    checkbox: str\n    parent_id: str | None\n    explicit_id: bool\n    priority: str\n    blocking: bool\n    deps: List[str]\n    locks: List[str]\n    lines: List[str]\n\n\n@dataclass\nclass HandoffItem:\n    item_id: str\n    title: str\n    status: str\n    checkbox: str\n    priority: str\n    blocking: bool\n    source: str\n    lines: List[str]\n\n\n@dataclass\nclass WorkItem:\n    kind: str\n    item_id: str\n    title: str\n    priority: str\n    blocking: bool\n    order_key: tuple\n\n\n@dataclass\nclass NormalizeResult:\n    updated_text: str\n    summary: List[str]\n    changed: bool\n\n\ndef parse_args(argv: Iterable[str] | None = None) -> argparse.Namespace:\n    parser = argparse.ArgumentParser(description=\"Validate tasklist readiness.\")\n    parser.add_argument(\"--ticket\", default=None, help=\"Feature ticket (defaults to docs/.active.json).\")\n    parser.add_argument(\"--slug-hint\", default=None, help=\"Optional slug hint override.\")\n    parser.add_argument(\"--branch\", default=\"\", help=\"Current branch name for branch filters.\")\n    parser.add_argument(\n        \"--config\",\n        default=\"config/gates.json\",\n        help=\"Path to gates configuration file (default: config/gates.json).\",\n    )\n    parser.add_argument(\n        \"--quiet-ok\",\n        action=\"store_true\",\n        help=\"Suppress output when the check passes.\",\n    )\n    parser.add_argument(\n        \"--verbose\",\n        action=\"store_true\",\n        help=\"Print skip diagnostics when the gate is disabled.\",\n    )\n    parser.add_argument(\n        \"--fix\",\n        action=\"store_true\",\n        help=\"Normalize tasklist in place.\",\n    )\n    parser.add_argument(\n        \"--dry-run\",\n        action=\"store_true\",\n        help=\"Show changes without modifying files (requires --fix).\",\n    )\n    return parser.parse_args(list(argv) if argv is not None else None)\n\n\ndef _tasklist_cache_path(root: Path) -> Path:\n    return root / \".cache\" / \"tasklist.hash\"\n\n\ndef _tasklist_hash(text: str) -> str:\n    return hashlib.sha256(text.encode(\"utf-8\")).hexdigest()\n\n\ndef _load_tasklist_cache(path: Path) -> dict:\n    if not path.exists():\n        return {}\n    try:\n        payload = json.loads(path.read_text(encoding=\"utf-8\"))\n    except json.JSONDecodeError:\n        return {}\n    return payload if isinstance(payload, dict) else {}\n\n\ndef _write_tasklist_cache(\n    path: Path,\n    *,\n    ticket: str,\n    stage: str,\n    hash_value: str,\n    config_hash: str,\n) -> None:\n    path.parent.mkdir(parents=True, exist_ok=True)\n    payload = {\n        \"ticket\": ticket,\n        \"stage\": stage,\n        \"hash\": hash_value,\n        \"config_hash\": config_hash,\n        \"updated_at\": datetime.now(timezone.utc).isoformat(timespec=\"seconds\"),\n    }\n    path.write_text(json.dumps(payload, ensure_ascii=False, indent=2) + \"\\n\", encoding=\"utf-8\")\n\n\ndef _config_fingerprint(path: Path) -> str:\n    if not path.exists():\n        return \"missing\"\n    try:\n        data = path.read_bytes()\n    except OSError:\n        return \"error\"\n    return hashlib.sha256(data).hexdigest()\n\n\ndef read_text(path: Path) -> str:\n    return path.read_text(encoding=\"utf-8\")\n\n\ndef parse_front_matter(lines: List[str]) -> tuple[dict[str, str], int]:\n    if not lines or lines[0].strip() != \"---\":\n        return {}, 0\n    end_idx = None\n    for idx in range(1, len(lines)):\n        if lines[idx].strip() == \"---\":\n            end_idx = idx\n            break\n    if end_idx is None:\n        return {}, 0\n    front: dict[str, str] = {}\n    for raw in lines[1:end_idx]:\n        line = raw.strip()\n        if not line or line.startswith(\"#\") or \":\" not in line:\n            continue\n        key, value = line.split(\":\", 1)\n        front[key.strip()] = value.strip()\n    return front, end_idx + 1\n\n\ndef parse_sections(lines: List[str]) -> tuple[List[Section], dict[str, List[Section]]]:\n    sections: List[Section] = []\n    for idx, line in enumerate(lines):\n        match = SECTION_HEADER_RE.match(line)\n        if not match:\n            continue\n        title = match.group(1).strip()\n        if not title.startswith(\"AIDD:\"):\n            continue\n        if sections:\n            sections[-1].end = idx\n        sections.append(Section(title=title, start=idx, end=len(lines), lines=[]))\n    for section in sections:\n        section.lines = lines[section.start:section.end]\n    mapped: dict[str, List[Section]] = {}\n    for section in sections:\n        mapped.setdefault(section.title, []).append(section)\n    return sections, mapped\n\n\ndef section_body(section: Section | None) -> List[str]:\n    if not section:\n        return []\n    return section.lines[1:]\n\n\ndef extract_field_value(lines: List[str], field: str) -> str | None:\n    pattern = re.compile(rf\"^\\s*(?:[-*]\\s*)?{re.escape(field)}\\s*:\\s*(.*)$\", re.IGNORECASE)\n    for line in lines:\n        match = pattern.match(line)\n        if match:\n            return match.group(1).strip()\n    return None\n\n\ndef block_has_heading(lines: List[str], heading: str) -> bool:\n    pattern = re.compile(rf\"^\\s*-\\s*{re.escape(heading)}\\s*:\\s*(.*)$\", re.IGNORECASE)\n    for line in lines:\n        if pattern.match(line):\n            return True\n    return False\n\n\ndef is_placeholder(value: str) -> bool:\n    stripped = value.strip()\n    lowered = stripped.lower()\n    if lowered in PLACEHOLDER_VALUES:\n        return True\n    return stripped.startswith(\"<\") and stripped.endswith(\">\")\n\n\ndef parse_inline_list(value: str) -> List[str]:\n    raw = value.strip()\n    if not raw:\n        return []\n    if raw.startswith(\"[\") and raw.endswith(\"]\"):\n        raw = raw[1:-1].strip()\n    if not raw:\n        return []\n    parts = raw.split(\",\") if \",\" in raw else raw.split()\n    items = [part.strip() for part in parts if part.strip()]\n    return [item for item in items if not is_placeholder(item)]\n\n\ndef extract_list_field(lines: List[str], field: str) -> List[str]:\n    pattern = re.compile(rf\"^(?P<indent>\\s*)-\\s*{re.escape(field)}\\s*:\\s*$\", re.IGNORECASE)\n    for idx, line in enumerate(lines):\n        match = pattern.match(line)\n        if not match:\n            continue\n        base_indent = len(match.group(\"indent\"))\n        items: List[str] = []\n        for raw in lines[idx + 1 :]:\n            if not raw.strip():\n                continue\n            indent = len(raw) - len(raw.lstrip(\" \"))\n            if indent <= base_indent and raw.lstrip().startswith(\"-\"):\n                break\n            if indent <= base_indent and raw.strip():\n                break\n            if raw.lstrip().startswith(\"-\") and indent > base_indent:\n                item = raw.lstrip()[2:].strip()\n                if item and not is_placeholder(item):\n                    items.append(item)\n        return items\n    return []\n\n\ndef extract_mapping_field(lines: List[str], field: str) -> Dict[str, str]:\n    pattern = re.compile(rf\"^(?P<indent>\\s*)-\\s*{re.escape(field)}\\s*:\\s*$\", re.IGNORECASE)\n    for idx, line in enumerate(lines):\n        match = pattern.match(line)\n        if not match:\n            continue\n        base_indent = len(match.group(\"indent\"))\n        result: Dict[str, str] = {}\n        for raw in lines[idx + 1 :]:\n            if not raw.strip():\n                continue\n            indent = len(raw) - len(raw.lstrip(\" \"))\n            if indent <= base_indent and raw.lstrip().startswith(\"-\"):\n                break\n            if indent <= base_indent and raw.strip():\n                break\n            if raw.lstrip().startswith(\"-\") and indent > base_indent:\n                item = raw.lstrip()[2:].strip()\n                if \":\" in item:\n                    key, value = item.split(\":\", 1)\n                    key = key.strip()\n                    value = value.strip()\n                    if key and not is_placeholder(key) and not is_placeholder(value):\n                        result[key] = value\n        return result\n    return {}\n\n\ndef normalize_dep_id(value: str) -> str:\n    raw = value.strip()\n    if not raw:\n        return \"\"\n    if \"iteration_id=\" in raw:\n        return raw.split(\"iteration_id=\", 1)[1].strip()\n    if \"id=\" in raw:\n        return raw.split(\"id=\", 1)[1].strip()\n    return raw\n\n\ndef parse_int(value: str | None) -> int | None:\n    raw = str(value or \"\").strip()\n    if not raw or is_placeholder(raw):\n        return None\n    try:\n        return int(raw)\n    except (TypeError, ValueError):\n        return None\n\n\ndef split_checkbox_blocks(lines: List[str]) -> List[List[str]]:\n    blocks: List[List[str]] = []\n    current: List[str] = []\n    for line in lines:\n        if CHECKBOX_RE.match(line):\n            if current:\n                blocks.append(current)\n                current = []\n            current.append(line)\n            continue\n        if current:\n            current.append(line)\n    if current:\n        blocks.append(current)\n    return blocks\n\n\ndef extract_iteration_id(block: List[str]) -> str | None:\n    for line in block:\n        match = ITERATION_ID_RE.search(line)\n        if match:\n            return match.group(1).strip()\n    header = block[0] if block else \"\"\n    match = re.search(r\"\\bI\\d+\\b\", header)\n    return match.group(0) if match else None\n\n\ndef extract_handoff_id(block: List[str]) -> str | None:\n    for line in block:\n        match = ID_RE.search(line)\n        if match:\n            return match.group(1).strip()\n    return None\n\n\ndef normalize_source(value: str | None) -> str:\n    normalized = (value or \"\").strip().lower()\n    if normalized == \"reviewer\":\n        return \"review\"\n    return normalized\n\n\ndef parse_parenthetical_fields(header: str) -> dict[str, str]:\n    fields: dict[str, str] = {}\n    for group in re.findall(r\"\\(([^\\)]+)\\)\", header):\n        if \":\" not in group:\n            continue\n        key, value = group.split(\":\", 1)\n        key = key.strip().lower()\n        fields[key] = value.strip()\n    return fields\n\n\ndef split_iteration_blocks(lines: List[str]) -> List[List[str]]:\n    blocks: List[List[str]] = []\n    current: List[str] = []\n    for line in lines:\n        stripped = line.lstrip()\n        if not stripped.startswith(\"-\"):\n            if current:\n                current.append(line)\n            continue\n        if line != stripped:\n            if current:\n                current.append(line)\n            continue\n        is_checkbox = bool(CHECKBOX_RE.match(line))\n        has_iteration = bool(ITERATION_ID_RE.search(line)) or bool(re.match(r\"^-\\s*I\\d+\\b\", line))\n        if is_checkbox or has_iteration:\n            if current:\n                blocks.append(current)\n            current = [line]\n            continue\n        if current:\n            current.append(line)\n    if current:\n        blocks.append(current)\n    return blocks\n\n\ndef parse_iteration_items(section_lines: List[str]) -> List[IterationItem]:\n    items: List[IterationItem] = []\n    for block in split_iteration_blocks(section_lines):\n        header = block[0].strip()\n        checkbox_state = \"unknown\"\n        checkbox_match = CHECKBOX_RE.match(header)\n        if checkbox_match:\n            checkbox_state = \"done\" if checkbox_match.group(\"state\").lower() == \"x\" else \"open\"\n        fields = parse_parenthetical_fields(header)\n        iteration_id = extract_iteration_id(block) or \"\"\n        explicit_id = any(ITERATION_ID_RE.search(line) for line in block)\n        parent_id = None\n        for line in block:\n            parent_match = PARENT_ITERATION_RE.search(line)\n            if parent_match:\n                parent_id = parent_match.group(1).strip()\n                break\n        state_value = extract_field_value(block, \"State\")\n        state = (state_value or \"\").strip().lower()\n        if not state:\n            state = \"\"\n        title = header\n        if checkbox_match:\n            title = checkbox_match.group(\"body\").strip()\n        else:\n            if title.startswith(\"-\"):\n                title = title.lstrip(\"-\").strip()\n        title = re.sub(r\"\\(iteration_id\\s*[:=].*?\\)\", \"\", title, flags=re.IGNORECASE).strip()\n        if iteration_id:\n            title = re.sub(rf\"^{re.escape(iteration_id)}\\s*[:\\-]\\s*\", \"\", title, flags=re.IGNORECASE).strip()\n        priority = (fields.get(\"priority\") or extract_field_value(block, \"Priority\") or \"\").strip().lower()\n        blocking_raw = (fields.get(\"blocking\") or extract_field_value(block, \"Blocking\") or \"\").strip().lower()\n        blocking = blocking_raw == \"true\"\n        deps = parse_inline_list(extract_field_value(block, \"deps\") or \"\")\n        if not deps:\n            deps = extract_list_field(block, \"deps\")\n        locks = parse_inline_list(extract_field_value(block, \"locks\") or \"\")\n        if not locks:\n            locks = extract_list_field(block, \"locks\")\n        deps = [normalize_dep_id(dep) for dep in deps if dep]\n        items.append(\n            IterationItem(\n                item_id=iteration_id,\n                title=title,\n                state=state,\n                checkbox=checkbox_state,\n                parent_id=parent_id,\n                explicit_id=explicit_id,\n                priority=priority,\n                blocking=blocking,\n                deps=deps,\n                locks=locks,\n                lines=block,\n            )\n        )\n    return items\n\n\ndef parse_handoff_items(section_lines: List[str]) -> List[HandoffItem]:\n    parsed: List[HandoffItem] = []\n    for block in split_checkbox_blocks(section_lines):\n        header = block[0]\n        checkbox_state = \"unknown\"\n        match = CHECKBOX_RE.match(header)\n        if match:\n            checkbox_state = \"done\" if match.group(\"state\").lower() == \"x\" else \"open\"\n        title = match.group(\"body\").strip() if match else header.strip()\n        title = re.sub(r\"\\([^\\)]*\\)\", \"\", title).strip()\n        fields = parse_parenthetical_fields(header)\n        item_id = fields.get(\"id\") or extract_handoff_id(block) or \"\"\n        priority = (fields.get(\"priority\") or extract_field_value(block, \"Priority\") or \"\").strip().lower()\n        blocking_raw = (fields.get(\"blocking\") or extract_field_value(block, \"Blocking\") or \"\").strip().lower()\n        blocking = blocking_raw == \"true\"\n        source = normalize_source(extract_field_value(block, \"source\") or fields.get(\"source\"))\n        status = (extract_field_value(block, \"Status\") or \"\").strip().lower()\n        if not status and checkbox_state in {\"open\", \"done\"}:\n            status = checkbox_state\n        parsed.append(\n            HandoffItem(\n                item_id=item_id,\n                title=title,\n                status=status,\n                checkbox=checkbox_state,\n                priority=priority,\n                blocking=blocking,\n                source=source,\n                lines=block,\n            )\n        )\n    return parsed\n\n\ndef parse_next3_items(section_lines: List[str]) -> List[List[str]]:\n    return split_checkbox_blocks(section_lines)\n\n\ndef extract_ref_id(block: List[str]) -> tuple[str, str | None, bool]:\n    ref_value = None\n    for line in block:\n        match = REF_RE.search(line)\n        if match:\n            ref_value = match.group(1).strip()\n            break\n    if ref_value:\n        if \"iteration_id=\" in ref_value:\n            return \"iteration\", ref_value.split(\"iteration_id=\", 1)[1].strip(), True\n        if \"id=\" in ref_value:\n            return \"handoff\", ref_value.split(\"id=\", 1)[1].strip(), True\n    for line in block:\n        match = ITERATION_ID_RE.search(line)\n        if match:\n            return \"iteration\", match.group(1).strip(), False\n        match = ID_RE.search(line)\n        if match:\n            return \"handoff\", match.group(1).strip(), False\n    return \"\", None, False\n\n\ndef progress_entries_from_lines(lines: List[str]) -> tuple[List[dict], List[str]]:\n    entries: List[dict] = []\n    invalid: List[str] = []\n    for raw in lines:\n        if not raw.strip().startswith(\"-\"):\n            continue\n        stripped = raw.strip().lower()\n        if stripped.startswith(\"- (empty)\") or stripped.startswith(\"- ...\"):\n            continue\n        match = PROGRESS_LINE_RE.match(raw)\n        if not match:\n            invalid.append(raw)\n            continue\n        info = match.groupdict()\n        info[\"source\"] = info[\"source\"].lower()\n        info[\"kind\"] = info[\"kind\"].lower()\n        info[\"msg\"] = info[\"msg\"].strip()\n        entries.append(info)\n    return entries, invalid\n\n\ndef dedupe_progress(entries: List[dict]) -> List[dict]:\n    seen = set()\n    deduped: List[dict] = []\n    for entry in entries:\n        key = (entry.get(\"date\"), entry.get(\"source\"), entry.get(\"item_id\"), entry.get(\"hash\"))\n        if key in seen:\n            continue\n        seen.add(key)\n        deduped.append(entry)\n    return deduped\n\n\ndef progress_entry_line(entry: dict) -> str:\n    parts = [\n        f\"- {entry['date']}\",\n        f\"source={entry['source']}\",\n        f\"id={entry['item_id']}\",\n        f\"kind={entry['kind']}\",\n        f\"hash={entry['hash']}\",\n    ]\n    if entry.get(\"link\"):\n        parts.append(f\"link={entry['link']}\")\n    msg = entry.get(\"msg\") or \"\"\n    if len(msg) > 200:\n        msg = msg[:197] + \"...\"\n    parts.append(f\"msg={msg}\")\n    line = \" \".join(parts)\n    if len(line) > 240:\n        line = line[:237] + \"...\"\n    return line\n\n\ndef load_gate_config(path: Path) -> dict | None:\n    if not path.is_file():\n        return None\n    try:\n        data = gates.load_gates_config(path)\n    except ValueError:\n        return None\n    if \"tasklist_spec\" not in data:\n        return None\n    section = data.get(\"tasklist_spec\")\n    if isinstance(section, bool):\n        return {\"enabled\": section}\n    return section if isinstance(section, dict) else None\n\n\ndef should_skip_gate(gate: dict | None, branch: str) -> tuple[bool, str]:\n    if gate is None:\n        return True, \"gate config missing\"\n    enabled = bool(gate.get(\"enabled\", True))\n    if not enabled:\n        return True, \"gate disabled\"\n    if branch and gates.matches(gate.get(\"skip_branches\"), branch):\n        return True, \"branch skipped\"\n    branches = gate.get(\"branches\")\n    if branch and branches and not gates.matches(branches, branch):\n        return True, \"branch not in allowlist\"\n    return False, \"\"\n\n\ndef severity_for_stage(stage: str, *, strict: bool = False) -> str:\n    normalized = (stage or \"\").strip().lower()\n    if strict or normalized in STRICT_STAGES:\n        return \"error\"\n    return \"warn\"\n\n\ndef resolve_stage(root: Path, context_pack: List[str]) -> str:\n    value = runtime.read_active_stage(root)\n    if value:\n        return value.lower()\n    stage_value = extract_field_value(context_pack, \"Stage\")\n    return (stage_value or \"\").strip().lower()\n\n\ndef parse_plan_iteration_ids(root: Path, plan_path: Path) -> list[str]:\n    try:\n        text = plan_path.read_text(encoding=\"utf-8\")\n    except OSError:\n        return []\n    lines = text.splitlines()\n    _, sections = parse_sections(lines)\n    plan_section = sections.get(\"AIDD:ITERATIONS\")\n    if not plan_section:\n        return []\n    ids: list[str] = []\n    for line in section_body(plan_section[0]):\n        match = ITERATION_ID_RE.search(line)\n        if match:\n            ids.append(match.group(1).strip())\n    return ids\n\n\ndef pick_open_state(checkbox_state: str, state_value: str) -> tuple[Optional[bool], str]:\n    state = (state_value or \"\").strip().lower()\n    if state and state not in ITERATION_STATE_VALUES:\n        return None, state\n    if checkbox_state == \"done\" or state == \"done\":\n        return False, state\n    if checkbox_state == \"open\" or state in {\"open\", \"blocked\"}:\n        return True, state\n    return None, state\n\n\ndef handoff_open_state(checkbox_state: str, status: str) -> tuple[Optional[bool], str]:\n    status_value = (status or \"\").strip().lower()\n    if status_value and status_value not in HANDOFF_STATUS_VALUES:\n        return None, status_value\n    if checkbox_state == \"done\" or status_value == \"done\":\n        return False, status_value\n    if checkbox_state == \"open\" or status_value in {\"open\", \"blocked\"}:\n        return True, status_value\n    return None, status_value\n\n\ndef next3_placeholder_present(lines: List[str]) -> bool:\n    for line in lines:\n        stripped = line.strip().lower()\n        if stripped.startswith(\"- (none)\") or \"no pending\" in stripped:\n            return True\n    return False\n\n\ndef extract_bullets(lines: List[str]) -> int:\n    count = 0\n    for line in lines:\n        if re.match(r\"^\\s*-\\s+\", line):\n            count += 1\n    return count\n\n\ndef subsection_lines(section_lines: List[str], heading: str) -> List[str]:\n    start = None\n    for idx, line in enumerate(section_lines):\n        if line.strip().lower() == heading.lower():\n            start = idx + 1\n            break\n    if start is None:\n        return []\n    end = len(section_lines)\n    for idx in range(start, len(section_lines)):\n        if section_lines[idx].strip().startswith(\"### \"):\n            end = idx\n            break\n    return section_lines[start:end]\n\n\ndef collect_stacktrace_flags(lines: List[str]) -> bool:\n    at_count = 0\n    caused_count = 0\n    in_fence = False\n    fence_count = 0\n    for line in lines:\n        stripped = line.rstrip()\n        if stripped.startswith(\"```\"):\n            in_fence = not in_fence\n            if not in_fence:\n                if fence_count > 20:\n                    return True\n                fence_count = 0\n            continue\n        if in_fence:\n            fence_count += 1\n            continue\n        if re.match(r\"^\\s+at\\s+\", stripped):\n            at_count += 1\n            if at_count >= 5:\n                return True\n        else:\n            at_count = 0\n        if stripped.startswith(\"Caused by:\"):\n            caused_count += 1\n            if caused_count >= 2:\n                return True\n        else:\n            caused_count = 0\n    return False\n\n\ndef large_code_fence_without_report(lines: List[str]) -> bool:\n    in_fence = False\n    fence_lines: List[int] = []\n    start_idx = 0\n    for idx, line in enumerate(lines):\n        if line.strip().startswith(\"```\"):\n            if not in_fence:\n                in_fence = True\n                fence_lines = []\n                start_idx = idx\n            else:\n                in_fence = False\n                if len(fence_lines) > 20 and not find_report_link_near(lines, start_idx):\n                    return True\n            continue\n        if in_fence:\n            fence_lines.append(idx)\n    return False\n\n\ndef find_report_link_near(lines: List[str], idx: int, window: int = 5) -> bool:\n    start = max(0, idx - window)\n    end = min(len(lines), idx + window + 1)\n    for line in lines[start:end]:\n        if \"aidd/reports/\" in line:\n            return True\n    return False\n\n\ndef parse_qa_traceability(section_lines: List[str]) -> dict[str, dict]:\n    result: dict[str, dict] = {}\n    for line in section_lines:\n        match = re.search(r\"\\bAC-([A-Za-z0-9_-]+)\\b\", line)\n        if not match:\n            continue\n        ac_id = match.group(1)\n        status_match = re.search(r\"\\b(not[- ]met|not[- ]verified|met)\\b\", line, re.IGNORECASE)\n        status = status_match.group(1).lower() if status_match else \"\"\n        status = status.replace(\" \", \"-\")\n        evidence = \"\"\n        if \"→\" in line:\n            parts = [part.strip() for part in line.split(\"→\")]\n            if len(parts) >= 4:\n                evidence = parts[-1]\n        result.setdefault(ac_id, {\"status\": status, \"evidence\": []})\n        if status:\n            current = result[ac_id][\"status\"]\n            order = {\"met\": 0, \"not-verified\": 1, \"not-met\": 2}\n            if current in order and status in order:\n                if order[status] > order[current]:\n                    result[ac_id][\"status\"] = status\n            else:\n                result[ac_id][\"status\"] = status\n        if evidence:\n            result[ac_id][\"evidence\"].append(evidence)\n    return result\n\n\ndef resolve_plan_path(root: Path, front: dict[str, str], ticket: str) -> Path:\n    plan = front.get(\"Plan\") or front.get(\"plan\") or \"\"\n    if plan:\n        raw = Path(plan)\n        if not raw.is_absolute():\n            if raw.parts and raw.parts[0] == \"aidd\" and root.name == \"aidd\":\n                return root / Path(*raw.parts[1:])\n            return root / raw\n        return raw\n    return root / \"docs\" / \"plan\" / f\"{ticket}.md\"\n\n\ndef resolve_prd_path(root: Path, front: dict[str, str], ticket: str) -> Path:\n    prd = front.get(\"PRD\") or front.get(\"prd\") or \"\"\n    if prd:\n        raw = Path(prd)\n        if not raw.is_absolute():\n            if raw.parts and raw.parts[0] == \"aidd\" and root.name == \"aidd\":\n                return root / Path(*raw.parts[1:])\n            return root / raw\n        return raw\n    return root / \"docs\" / \"prd\" / f\"{ticket}.prd.md\"\n\n\ndef resolve_spec_path(root: Path, front: dict[str, str], ticket: str) -> Path | None:\n    spec = front.get(\"Spec\") or front.get(\"spec\") or \"\"\n    if spec:\n        lowered = spec.strip().lower()\n        if is_placeholder(spec) or lowered in SPEC_PLACEHOLDERS:\n            return None\n        raw = Path(spec)\n        if not raw.is_absolute():\n            if raw.parts and raw.parts[0] == \"aidd\" and root.name == \"aidd\":\n                return root / Path(*raw.parts[1:])\n            return root / raw\n        return raw\n    return root / \"docs\" / \"spec\" / f\"{ticket}.spec.yaml\"\n\n\ndef rel_path(root: Path, path: Path) -> str:\n    try:\n        return path.relative_to(root).as_posix()\n    except ValueError:\n        return str(path)\n\n\ndef extract_section_text(text: str, titles: Iterable[str]) -> str:\n    lines = text.splitlines()\n    _, section_map = parse_sections(lines)\n    collected: List[str] = []\n    for title in titles:\n        for section in section_map.get(title, []):\n            collected.extend(section_body(section))\n    return \"\\n\".join(collected) if collected else text\n\n\ndef mentions_spec_required(text: str) -> bool:\n    if not text:\n        return False\n    return any(pattern.search(text) for pattern in SPEC_REQUIRED_PATTERNS)\n\n\ndef tasklist_path_for(root: Path, ticket: str) -> Path:\n    return root / \"docs\" / \"tasklist\" / f\"{ticket}.md\"\n\n\ndef progress_archive_path(root: Path, ticket: str) -> Path:\n    return root / \"reports\" / \"progress\" / f\"{ticket}.log\"\n\n\ndef deps_satisfied(\n    deps: List[str],\n    iteration_map: dict[str, IterationItem],\n    handoff_map: dict[str, HandoffItem],\n) -> bool:\n    from aidd_runtime import tasklist_normalize as _tasklist_normalize\n\n    return _tasklist_normalize.deps_satisfied(deps, iteration_map, handoff_map)\n\n\ndef unmet_deps(\n    deps: List[str],\n    iteration_map: dict[str, IterationItem],\n    handoff_map: dict[str, HandoffItem],\n) -> List[str]:\n    from aidd_runtime import tasklist_normalize as _tasklist_normalize\n\n    return _tasklist_normalize.unmet_deps(deps, iteration_map, handoff_map)\n\n\ndef build_open_items(\n    iterations: List[IterationItem],\n    handoff_items: List[HandoffItem],\n    plan_order: List[str],\n) -> tuple[List[WorkItem], dict[str, IterationItem], dict[str, HandoffItem]]:\n    from aidd_runtime import tasklist_normalize as _tasklist_normalize\n\n    return _tasklist_normalize.build_open_items(iterations, handoff_items, plan_order)\n\n\ndef build_next3_lines(open_items: List[WorkItem], preamble: List[str] | None = None) -> List[str]:\n    from aidd_runtime import tasklist_normalize as _tasklist_normalize\n\n    return _tasklist_normalize.build_next3_lines(open_items, preamble)\n\n\ndef normalize_progress_section(\n    lines: List[str],\n    ticket: str,\n    root: Path,\n    summary: List[str],\n    *,\n    dry_run: bool,\n) -> List[str]:\n    from aidd_runtime import tasklist_normalize as _tasklist_normalize\n\n    return _tasklist_normalize.normalize_progress_section(lines, ticket, root, summary, dry_run=dry_run)\n\n\ndef normalize_qa_traceability(lines: List[str], summary: List[str]) -> List[str]:\n    from aidd_runtime import tasklist_normalize as _tasklist_normalize\n\n    return _tasklist_normalize.normalize_qa_traceability(lines, summary)\n\n\ndef normalize_handoff_section(sections: List[Section], summary: List[str]) -> List[str]:\n    from aidd_runtime import tasklist_normalize as _tasklist_normalize\n\n    return _tasklist_normalize.normalize_handoff_section(sections, summary)\n\n\ndef normalize_tasklist(\n    root: Path,\n    ticket: str,\n    text: str,\n    *,\n    dry_run: bool = False,\n) -> NormalizeResult:\n    from aidd_runtime import tasklist_normalize as _tasklist_normalize\n\n    return _tasklist_normalize.normalize_tasklist(root, ticket, text, dry_run=dry_run)\n\n\ndef check_tasklist_text(\n    root: Path,\n    ticket: str,\n    text: str,\n    *,\n    normalize_fix_mode: bool = False,\n) -> TasklistCheckResult:\n    from aidd_runtime import tasklist_validate as _tasklist_validate\n\n    return _tasklist_validate.check_tasklist_text(\n        root,\n        ticket,\n        text,\n        normalize_fix_mode=normalize_fix_mode,\n    )\n\ndef check_tasklist(\n    root: Path,\n    ticket: str,\n    *,\n    normalize_fix_mode: bool = False,\n) -> TasklistCheckResult:\n    tasklist_path = tasklist_path_for(root, ticket)\n    if not tasklist_path.exists():\n        return TasklistCheckResult(status=\"error\", message=f\"tasklist not found: {tasklist_path}\")\n    text = read_text(tasklist_path)\n    return check_tasklist_text(root, ticket, text, normalize_fix_mode=normalize_fix_mode)\n\n\ndef run_check(args: argparse.Namespace) -> int:\n    root = resolve_aidd_root(Path.cwd())\n    config_path = Path(args.config)\n    if not config_path.is_absolute():\n        config_path = root / config_path\n\n    if args.fix and args.dry_run:\n        pass\n\n    if not args.fix:\n        gate = load_gate_config(config_path)\n        skip_gate, skip_reason = should_skip_gate(gate, args.branch or \"\")\n        if skip_gate:\n            if args.verbose:\n                print(f\"[tasklist-check] SKIP: {skip_reason}\", file=sys.stderr)\n            return 0\n\n    identifiers = resolve_identifiers(root, ticket=args.ticket, slug_hint=args.slug_hint)\n    ticket = (identifiers.resolved_ticket or \"\").strip()\n    if not ticket:\n        result = TasklistCheckResult(status=\"error\", message=\"ticket not provided and docs/.active.json missing\")\n    else:\n        tasklist_path = tasklist_path_for(root, ticket)\n        if not tasklist_path.exists():\n            result = TasklistCheckResult(status=\"error\", message=f\"tasklist not found: {tasklist_path}\")\n        else:\n            tasklist_text = tasklist_path.read_text(encoding=\"utf-8\")\n            stage_value = runtime.read_active_stage(root)\n            cache_path = _tasklist_cache_path(root)\n            current_hash = _tasklist_hash(tasklist_text)\n            config_hash = _config_fingerprint(config_path)\n\n            if not args.fix and not args.dry_run:\n                cache_payload = _load_tasklist_cache(cache_path)\n                if (\n                    cache_payload.get(\"ticket\") == ticket\n                    and cache_payload.get(\"stage\") == stage_value\n                    and cache_payload.get(\"hash\") == current_hash\n                    and cache_payload.get(\"config_hash\") == config_hash\n                ):\n                    if not args.quiet_ok:\n                        print(\"[tasklist-check] SKIP: cache hit (reason_code=cache_hit)\", file=sys.stderr)\n                    return 0\n\n            if args.fix:\n                original = tasklist_text\n                normalized = normalize_tasklist(root, ticket, original, dry_run=args.dry_run)\n                if args.dry_run:\n                    diff = difflib.unified_diff(\n                        original.splitlines(),\n                        normalized.updated_text.splitlines(),\n                        fromfile=str(tasklist_path),\n                        tofile=str(tasklist_path),\n                        lineterm=\"\",\n                    )\n                    for line in diff:\n                        print(line)\n                    for line in normalized.summary:\n                        print(f\"[tasklist-check] {line}\")\n                    return 0\n                if normalized.changed:\n                    backup_dir = root / \"reports\" / \"tasklist_backups\" / ticket\n                    backup_dir.mkdir(parents=True, exist_ok=True)\n                    timestamp = datetime.now(timezone.utc).strftime(\"%Y%m%d%H%M%S\")\n                    backup_path = backup_dir / f\"{timestamp}.md\"\n                    backup_path.write_text(original, encoding=\"utf-8\")\n                    tasklist_path.write_text(normalized.updated_text, encoding=\"utf-8\")\n                    for line in normalized.summary:\n                        print(f\"[tasklist-check] {line}\")\n                    print(f\"[tasklist-check] backup saved: {backup_path}\")\n                result = check_tasklist(root, ticket, normalize_fix_mode=True)\n            else:\n                result = check_tasklist_text(root, ticket, tasklist_text)\n\n            if result.status in {\"ok\", \"warn\"}:\n                updated_text = tasklist_path.read_text(encoding=\"utf-8\")\n                updated_hash = _tasklist_hash(updated_text)\n                _write_tasklist_cache(\n                    cache_path,\n                    ticket=ticket,\n                    stage=stage_value,\n                    hash_value=updated_hash,\n                    config_hash=config_hash,\n                )\n            if result.status == \"error\":\n                if result.details:\n                    for entry in result.details:\n                        print(f\"[tasklist-check] {entry}\", file=sys.stderr)\n                print(f\"[tasklist-check] FAIL: {result.message}\", file=sys.stderr)\n                return result.exit_code()\n            if result.status == \"warn\":\n                if result.details:\n                    for entry in result.details:\n                        print(f\"[tasklist-check] WARN: {entry}\", file=sys.stderr)\n            return result.exit_code()\n    if result.status == \"error\":\n        if result.details:\n            for entry in result.details:\n                print(f\"[tasklist-check] {entry}\", file=sys.stderr)\n        print(f\"[tasklist-check] FAIL: {result.message}\", file=sys.stderr)\n        return result.exit_code()\n\n    if result.status == \"warn\":\n        if result.details:\n            for entry in result.details:\n                print(f\"[tasklist-check] WARN: {entry}\", file=sys.stderr)\n        return result.exit_code()\n\n    if result.status == \"ok\" and not args.quiet_ok:\n        print(\"[tasklist-check] OK: tasklist READY\", file=sys.stderr)\n    return result.exit_code()\n\n\ndef main(argv: Iterable[str] | None = None) -> int:\n    args = parse_args(argv)\n    return run_check(args)\n\n\nif __name__ == \"__main__\":  # pragma: no cover\n    raise SystemExit(main())\n","numLines":1199,"startLine":1,"totalLines":1199}}}
