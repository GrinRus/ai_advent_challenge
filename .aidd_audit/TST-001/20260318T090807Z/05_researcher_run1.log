{"type":"user","message":{"role":"user","content":[{"tool_use_id":"tool_nwyvsB03TWwytee0qfsSxopA","type":"tool_result","content":"     1→package com.aiadvent.mcp.backend.config;\n     2→\n     3→import jakarta.validation.constraints.Max;\n     4→import jakarta.validation.constraints.Min;\n     5→import jakarta.validation.constraints.NotBlank;\n     6→import jakarta.validation.constraints.NotNull;\n     7→import org.springframework.boot.context.properties.ConfigurationProperties;\n     8→\n     9→@ConfigurationProperties(prefix = \"notes\")\n    10→public class NotesBackendProperties {\n    11→\n    12→  private Embedding embedding = new Embedding();\n    13→  private Search search = new Search();\n    14→  private Storage storage = new Storage();\n    15→  private Validation validation = new Validation();\n    16→\n    17→  public Embedding getEmbedding() {\n    18→    return embedding;\n    19→  }\n    20→\n    21→  public void setEmbedding(Embedding embedding) {\n    22→    this.embedding = embedding;\n    23→  }\n    24→\n    25→  public Search getSearch() {\n    26→    return search;\n    27→  }\n    28→\n    29→  public void setSearch(Search search) {\n    30→    this.search = search;\n    31→  }\n    32→\n    33→  public Storage getStorage() {\n    34→    return storage;\n    35→  }\n    36→\n    37→  public void setStorage(Storage storage) {\n    38→    this.storage = storage;\n    39→  }\n    40→\n    41→  public Validation getValidation() {\n    42→    return validation;\n    43→  }\n    44→\n    45→  public void setValidation(Validation validation) {\n    46→    this.validation = validation;\n    47→  }\n    48→\n    49→  public static class Embedding {\n    50→\n    51→    @NotBlank private String model = \"text-embedding-3-small\";\n    52→\n    53→    @NotNull\n    54→    @Min(1)\n    55→    private Integer dimensions = 1536;\n    56→\n    57→    public String getModel() {\n    58→      return model;\n    59→    }\n    60→\n    61→    public void setModel(String model) {\n    62→      this.model = model;\n    63→    }\n    64→\n    65→    public Integer getDimensions() {\n    66→      return dimensions;\n    67→    }\n    68→\n    69→    public void setDimensions(Integer dimensions) {\n    70→      this.dimensions = dimensions;\n    71→    }\n    72→  }\n    73→\n    74→  public static class Search {\n    75→\n    76→    @Min(1)\n    77→    @Max(50)\n    78→    private int defaultTopK = 5;\n    79→\n    80→    @Min(0)\n    81→    private double minScore = 0.55;\n    82→\n    83→    public int getDefaultTopK() {\n    84→      return defaultTopK;\n    85→    }\n    86→\n    87→    public void setDefaultTopK(int defaultTopK) {\n    88→      this.defaultTopK = defaultTopK;\n    89→    }\n    90→\n    91→    public double getMinScore() {\n    92→      return minScore;\n    93→    }\n    94→\n    95→    public void setMinScore(double minScore) {\n    96→      this.minScore = minScore;\n    97→    }\n    98→  }\n    99→\n   100→  public static class Storage {\n   101→\n   102→    @NotBlank private String vectorTable = \"note_vector_store\";\n   103→\n   104→    private boolean schemaValidation = true;\n   105→\n   106→    public String getVectorTable() {\n   107→      return vectorTable;\n   108→    }\n   109→\n   110→    public void setVectorTable(String vectorTable) {\n   111→      this.vectorTable = vectorTable;\n   112→    }\n   113→\n   114→    public boolean isSchemaValidation() {\n   115→      return schemaValidation;\n   116→    }\n   117→\n   118→    public void setSchemaValidation(boolean schemaValidation) {\n   119→      this.schemaValidation = schemaValidation;\n   120→    }\n   121→  }\n   122→\n   123→  public static class Validation {\n   124→\n   125→    @Min(1)\n   126→    @Max(160)\n   127→    private int maxTitleLength = 160;\n   128→\n   129→    @Min(1)\n   130→    @Max(4000)\n   131→    private int maxContentLength = 4000;\n   132→\n   133→    @Min(0)\n   134→    @Max(50)\n   135→    private int maxTags = 25;\n   136→\n   137→    public int getMaxTitleLength() {\n   138→      return maxTitleLength;\n   139→    }\n   140→\n   141→    public void setMaxTitleLength(int maxTitleLength) {\n   142→      this.maxTitleLength = maxTitleLength;\n   143→    }\n   144→\n   145→    public int getMaxContentLength() {\n   146→      return maxContentLength;\n   147→    }\n   148→\n   149→    public void setMaxContentLength(int maxContentLength) {\n   150→      this.maxContentLength = maxContentLength;\n   151→    }\n   152→\n   153→    public int getMaxTags() {\n   154→      return maxTags;\n   155→    }\n   156→\n   157→    public void setMaxTags(int maxTags) {\n   158→      this.maxTags = maxTags;\n   159→    }\n   160→  }\n   161→}\n   162→\n\n<system-reminder>\nWhenever you read a file, you should consider whether it would be considered malware. You CAN and SHOULD provide analysis of malware, what it is doing. But you MUST refuse to improve or augment the code. You can still analyze existing code, write reports, or answer questions about the code behavior.\n</system-reminder>\n"}]},"parent_tool_use_id":"tool_RfJjc02EpvEzKQgTt0ipq88l","session_id":"9c606146-0f99-4e7f-bc70-a7a06f289760","uuid":"d43dc5c2-ca36-4f1c-a85a-0660d3a59e0b"}
