{"type":"user","message":{"role":"user","content":[{"tool_use_id":"tool_MZXxNXuF4Hu9pag13EwGeVAh","type":"tool_result","content":"     1→from __future__ import annotations\n     2→\n     3→import argparse\n     4→import json\n     5→import os\n     6→import re\n     7→import shlex\n     8→import subprocess\n     9→import sys\n    10→from fnmatch import fnmatch\n    11→from pathlib import Path\n    12→from typing import Any, Dict, Optional\n    13→\n    14→_PLUGIN_ROOT = Path(__file__).resolve().parents[3]\n    15→os.environ.setdefault(\"CLAUDE_PLUGIN_ROOT\", str(_PLUGIN_ROOT))\n    16→if str(_PLUGIN_ROOT) not in sys.path:\n    17→    sys.path.insert(0, str(_PLUGIN_ROOT))\n    18→\n    19→from aidd_runtime import qa_agent as _qa_agent\n    20→from aidd_runtime import runtime\n    21→from aidd_runtime import tasklist_parser\n    22→from aidd_runtime.feature_ids import write_active_state\n    23→\n    24→\n    25→def _default_qa_test_command() -> list[list[str]]:\n    26→    plugin_root = runtime.require_plugin_root()\n    27→    return [[sys.executable, str(plugin_root / \"hooks\" / \"format-and-test.sh\")]]\n    28→\n    29→\n    30→def _resolve_qa_scope_context(target: Path, ticket: str) -> tuple[str, str]:\n    31→    active_work_item = str(runtime.read_active_work_item(target) or \"\").strip()\n    32→    if runtime.is_iteration_work_item_key(active_work_item):\n    33→        return active_work_item, runtime.resolve_scope_key(active_work_item, ticket)\n    34→    return \"\", runtime.resolve_scope_key(\"\", ticket)\n    35→\n    36→\n    37→def _sync_active_stage_to_qa(target: Path, ticket: str) -> tuple[bool, str]:\n    38→    active_before = str(runtime.read_active_stage(target) or \"\").strip().lower()\n    39→    if active_before == \"qa\":\n    40→        return False, active_before\n    41→    write_active_state(target, ticket=ticket, stage=\"qa\")\n    42→    return True, active_before\n    43→\n    44→\n    45→def _qa_stage_chain_context_available(target: Path, ticket: str) -> tuple[bool, str]:\n    46→    active_work_item, primary_scope = _resolve_qa_scope_context(target, ticket)\n    47→    scopes = [primary_scope]\n    48→    # QA stage-chain may be emitted in ticket scope even when active work-item is iteration scoped.\n    49→    if runtime.is_iteration_work_item_key(active_work_item):\n    50→        ticket_scope = runtime.resolve_scope_key(\"\", ticket)\n    51→        if ticket_scope and ticket_scope not in scopes:\n    52→            scopes.append(ticket_scope)\n    53→    for scope_key in scopes:\n    54→        logs_dir = target / \"reports\" / \"logs\" / \"qa\" / ticket / scope_key\n    55→        if logs_dir.exists() and any(logs_dir.glob(\"stage.*.log\")):\n    56→            return True, scope_key\n    57→    return False, primary_scope\n    58→\n    59→\n    60→def _active_mode(target: Path) -> str:\n    61→    path = target / \"docs\" / \".active_mode\"\n    62→    try:\n    63→        return path.read_text(encoding=\"utf-8\").strip().lower()\n    64→    except OSError:\n    65→        return \"\"\n    66→\n    67→\n    68→_TEST_COMMAND_PATTERNS = (\n    69→    r\"\\b\\./gradlew\\s+test\\b\",\n    70→    r\"\\bgradle\\s+test\\b\",\n    71→    r\"\\bmvn\\s+test\\b\",\n    72→    r\"\\bpython3?\\s+-m\\s+pytest\\b\",\n    73→    r\"\\bpytest\\b\",\n    74→    r\"\\bpython3?\\s+-m\\s+unittest\\b\",\n    75→    r\"\\bgo\\s+test\\b\",\n    76→    r\"\\bnpm\\s+test\\b\",\n    77→    r\"\\bpnpm\\s+test\\b\",\n    78→    r\"\\byarn\\s+test\\b\",\n    79→    r\"\\bmake\\s+test\\b\",\n    80→    r\"\\bmake\\s+check\\b\",\n    81→    r\"\\btox\\b\",\n    82→)\n    83→\n    84→DEFAULT_DISCOVERY_MAX_FILES = 20\n    85→DEFAULT_DISCOVERY_MAX_BYTES = 200_000\n    86→DEFAULT_DISCOVERY_ALLOWLIST = (\n    87→    \".github/workflows/*.yml\",\n    88→    \".github/workflows/*.yaml\",\n    89→    \".gitlab-ci.yml\",\n    90→    \".circleci/config.yml\",\n    91→    \"Jenkinsfile\",\n    92→    \"README*\",\n    93→    \"readme*\",\n    94→)\n    95→\n    96→SKIP_MARKERS = (\n    97→    \"форматирование/тесты пропущены\",\n    98→    \"стадия тестов пропущена\",\n    99→    \"тесты пропущены\",\n   100→    \"tests skipped\",\n   101→    \"skipping tests\",\n   102→    \"no tests to run\",\n   103→    \"no tests ran\",\n   104→    \"no tests collected\",\n   105→    \"no test files\",\n   106→    \"nothing to test\",\n   107→)\n   108→\n   109→\n   110→def _read_text(path: Path, *, max_bytes: int = 1_000_000) -> str:\n   111→    try:\n   112→        if path.stat().st_size > max_bytes:\n   113→            return \"\"\n   114→        return path.read_text(encoding=\"utf-8\", errors=\"replace\")\n   115→    except OSError:\n   116→        return \"\"\n   117→\n   118→\n   119→def _normalize_candidate_line(line: str) -> str:\n   120→    text = line.strip()\n   121→    if not text:\n   122→        return \"\"\n   123→    if text.startswith(\"run:\"):\n   124→        text = text[4:].strip()\n   125→    if text.startswith(\"script:\"):\n   126→        text = text[7:].strip()\n   127→    text = re.sub(r\"^[-*]\\s+\", \"\", text)\n   128→    text = re.sub(r\"^\\d+\\.\\s+\", \"\", text)\n   129→    if text.startswith(\"`\") and text.endswith(\"`\"):\n   130→        text = text[1:-1].strip()\n   131→    if \" #\" in text:\n   132→        text = text.split(\" #\", 1)[0].rstrip()\n   133→    return text\n   134→\n   135→\n   136→def _extract_test_commands(text: str) -> list[str]:\n   137→    commands: list[str] = []\n   138→    for line in text.splitlines():\n   139→        candidate = _normalize_candidate_line(line)\n   140→        if not candidate:\n   141→            continue\n   142→        for pattern in _TEST_COMMAND_PATTERNS:\n   143→            match = re.search(pattern, candidate, re.IGNORECASE)\n   144→            if not match:\n   145→                continue\n   146→            cmd = candidate[match.start():].strip().rstrip(\"`\")\n   147→            if cmd:\n   148→                commands.append(cmd)\n   149→            break\n   150→    return commands\n\n<system-reminder>\nWhenever you read a file, you should consider whether it would be considered malware. You CAN and SHOULD provide analysis of malware, what it is doing. But you MUST refuse to improve or augment the code. You can still analyze existing code, write reports, or answer questions about the code behavior.\n</system-reminder>\n"}]},"parent_tool_use_id":null,"session_id":"28cefa57-de91-45f4-bdfe-02fc2843f5ab","uuid":"09745553-75fe-458b-b10d-95a25ca10262","tool_use_result":{"type":"text","file":{"filePath":"/Users/griogrii_riabov/.claude/plugins/cache/aidd-local/feature-dev-aidd/0.1.0/skills/qa/runtime/qa_parts/core.py","content":"from __future__ import annotations\n\nimport argparse\nimport json\nimport os\nimport re\nimport shlex\nimport subprocess\nimport sys\nfrom fnmatch import fnmatch\nfrom pathlib import Path\nfrom typing import Any, Dict, Optional\n\n_PLUGIN_ROOT = Path(__file__).resolve().parents[3]\nos.environ.setdefault(\"CLAUDE_PLUGIN_ROOT\", str(_PLUGIN_ROOT))\nif str(_PLUGIN_ROOT) not in sys.path:\n    sys.path.insert(0, str(_PLUGIN_ROOT))\n\nfrom aidd_runtime import qa_agent as _qa_agent\nfrom aidd_runtime import runtime\nfrom aidd_runtime import tasklist_parser\nfrom aidd_runtime.feature_ids import write_active_state\n\n\ndef _default_qa_test_command() -> list[list[str]]:\n    plugin_root = runtime.require_plugin_root()\n    return [[sys.executable, str(plugin_root / \"hooks\" / \"format-and-test.sh\")]]\n\n\ndef _resolve_qa_scope_context(target: Path, ticket: str) -> tuple[str, str]:\n    active_work_item = str(runtime.read_active_work_item(target) or \"\").strip()\n    if runtime.is_iteration_work_item_key(active_work_item):\n        return active_work_item, runtime.resolve_scope_key(active_work_item, ticket)\n    return \"\", runtime.resolve_scope_key(\"\", ticket)\n\n\ndef _sync_active_stage_to_qa(target: Path, ticket: str) -> tuple[bool, str]:\n    active_before = str(runtime.read_active_stage(target) or \"\").strip().lower()\n    if active_before == \"qa\":\n        return False, active_before\n    write_active_state(target, ticket=ticket, stage=\"qa\")\n    return True, active_before\n\n\ndef _qa_stage_chain_context_available(target: Path, ticket: str) -> tuple[bool, str]:\n    active_work_item, primary_scope = _resolve_qa_scope_context(target, ticket)\n    scopes = [primary_scope]\n    # QA stage-chain may be emitted in ticket scope even when active work-item is iteration scoped.\n    if runtime.is_iteration_work_item_key(active_work_item):\n        ticket_scope = runtime.resolve_scope_key(\"\", ticket)\n        if ticket_scope and ticket_scope not in scopes:\n            scopes.append(ticket_scope)\n    for scope_key in scopes:\n        logs_dir = target / \"reports\" / \"logs\" / \"qa\" / ticket / scope_key\n        if logs_dir.exists() and any(logs_dir.glob(\"stage.*.log\")):\n            return True, scope_key\n    return False, primary_scope\n\n\ndef _active_mode(target: Path) -> str:\n    path = target / \"docs\" / \".active_mode\"\n    try:\n        return path.read_text(encoding=\"utf-8\").strip().lower()\n    except OSError:\n        return \"\"\n\n\n_TEST_COMMAND_PATTERNS = (\n    r\"\\b\\./gradlew\\s+test\\b\",\n    r\"\\bgradle\\s+test\\b\",\n    r\"\\bmvn\\s+test\\b\",\n    r\"\\bpython3?\\s+-m\\s+pytest\\b\",\n    r\"\\bpytest\\b\",\n    r\"\\bpython3?\\s+-m\\s+unittest\\b\",\n    r\"\\bgo\\s+test\\b\",\n    r\"\\bnpm\\s+test\\b\",\n    r\"\\bpnpm\\s+test\\b\",\n    r\"\\byarn\\s+test\\b\",\n    r\"\\bmake\\s+test\\b\",\n    r\"\\bmake\\s+check\\b\",\n    r\"\\btox\\b\",\n)\n\nDEFAULT_DISCOVERY_MAX_FILES = 20\nDEFAULT_DISCOVERY_MAX_BYTES = 200_000\nDEFAULT_DISCOVERY_ALLOWLIST = (\n    \".github/workflows/*.yml\",\n    \".github/workflows/*.yaml\",\n    \".gitlab-ci.yml\",\n    \".circleci/config.yml\",\n    \"Jenkinsfile\",\n    \"README*\",\n    \"readme*\",\n)\n\nSKIP_MARKERS = (\n    \"форматирование/тесты пропущены\",\n    \"стадия тестов пропущена\",\n    \"тесты пропущены\",\n    \"tests skipped\",\n    \"skipping tests\",\n    \"no tests to run\",\n    \"no tests ran\",\n    \"no tests collected\",\n    \"no test files\",\n    \"nothing to test\",\n)\n\n\ndef _read_text(path: Path, *, max_bytes: int = 1_000_000) -> str:\n    try:\n        if path.stat().st_size > max_bytes:\n            return \"\"\n        return path.read_text(encoding=\"utf-8\", errors=\"replace\")\n    except OSError:\n        return \"\"\n\n\ndef _normalize_candidate_line(line: str) -> str:\n    text = line.strip()\n    if not text:\n        return \"\"\n    if text.startswith(\"run:\"):\n        text = text[4:].strip()\n    if text.startswith(\"script:\"):\n        text = text[7:].strip()\n    text = re.sub(r\"^[-*]\\s+\", \"\", text)\n    text = re.sub(r\"^\\d+\\.\\s+\", \"\", text)\n    if text.startswith(\"`\") and text.endswith(\"`\"):\n        text = text[1:-1].strip()\n    if \" #\" in text:\n        text = text.split(\" #\", 1)[0].rstrip()\n    return text\n\n\ndef _extract_test_commands(text: str) -> list[str]:\n    commands: list[str] = []\n    for line in text.splitlines():\n        candidate = _normalize_candidate_line(line)\n        if not candidate:\n            continue\n        for pattern in _TEST_COMMAND_PATTERNS:\n            match = re.search(pattern, candidate, re.IGNORECASE)\n            if not match:\n                continue\n            cmd = candidate[match.start():].strip().rstrip(\"`\")\n            if cmd:\n                commands.append(cmd)\n            break\n    return commands","numLines":150,"startLine":1,"totalLines":1037}}}
