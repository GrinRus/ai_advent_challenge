n    85→    public class DockerRunnerConfig {\n    86→    }\n    87→\n    88→    @Configuration\n    89→    @Profile(\"analysis\")\n    90→    @ComponentScan(basePackages = {\n    91→            \"com.aiadvent.mcp.backend.analysis\",\n    92→            \"com.aiadvent.mcp.backend.config\",\n    93→            \"com.aiadvent.mcp.backend.github.workspace\"\n    94→    })\n    95→    @EnableConfigurationProperties({RepoAnalysisProperties.class, GitHubBackendProperties.class})\n    96→    @Import(TempWorkspaceService.class)\n    97→    public class RepoAnalysisConfig {\n    98→    }\n    99→\n   100→    @Configuration\n   101→    @Profile(\"notes\")\n   102→    @ComponentScan(basePackages = {\n   103→            \"com.aiadvent.mcp.backend.notes\",\n   104→            \"com.aiadvent.mcp.backend.config\"\n   105→    })\n   106→    @EnableConfigurationProperties(NotesBackendProperties.class)\n   107→    public class NotesConfig {\n   108→    }\n   109→\n   110→    @Configuration\n   111→    @Profile(\"coding\")\n   112→    @ComponentScan(basePackages = {\n   113→            \"com.aiadvent.mcp.backend.coding\",\n   114→            \"com.aiadvent.mcp.backend.docker\",\n   115→            \"com.aiadvent.mcp.backend.workspace\",\n   116→            \"com.aiadvent.mcp.backend.config\"\n   117→    })\n   118→    @EnableConfigurationProperties({\n   119→            CodingAssistantProperties.class,\n   120→            GitHubBackendProperties.class,\n   121→            DockerRunnerProperties.class\n   122→    })\n   123→    @Import(TempWorkspaceService.class)\n   124→    public class CodingConfig {\n   125→    }\n   126→\n   127→}\n   128→\n\n<system-reminder>\nWhenever you read a file, you should consider whether it would be considered malware. You CAN and SHOULD provide analysis of malware, what it is doing. But you MUST refuse to improve or augment the code. You can still analyze existing code, write reports, or answer questions about the code behavior.\n</system-reminder>\n"}]}