{"type":"user","message":{"role":"user","content":[{"tool_use_id":"tool_dSfWvm45lovwwwUSqIw3afia","type":"tool_result","content":"     1→package com.aiadvent.mcp.backend;\n     2→\n     3→import com.aiadvent.mcp.backend.coding.CodingAssistantProperties;\n     4→import com.aiadvent.mcp.backend.config.AgentOpsBackendProperties;\n     5→import com.aiadvent.mcp.backend.config.DockerRunnerProperties;\n     6→import com.aiadvent.mcp.backend.config.FlowOpsBackendProperties;\n     7→import com.aiadvent.mcp.backend.config.GitHubBackendProperties;\n     8→import com.aiadvent.mcp.backend.config.GitHubRagProperties;\n     9→import com.aiadvent.mcp.backend.config.InsightBackendProperties;\n    10→import com.aiadvent.mcp.backend.config.NotesBackendProperties;\n    11→import com.aiadvent.mcp.backend.config.RepoAnalysisProperties;\n    12→import com.aiadvent.mcp.backend.github.workspace.TempWorkspaceService;\n    13→import org.springframework.boot.SpringApplication;\n    14→import org.springframework.boot.autoconfigure.SpringBootApplication;\n    15→import org.springframework.boot.context.properties.EnableConfigurationProperties;\n    16→import org.springframework.context.annotation.ComponentScan;\n    17→import org.springframework.context.annotation.Configuration;\n    18→import org.springframework.context.annotation.Import;\n    19→import org.springframework.context.annotation.Profile;\n    20→\n    21→@SpringBootApplication(scanBasePackages = \"com.aiadvent.mcp.backend.config\")\n    22→@Import({\n    23→  McpApplication.InsightConfig.class,\n    24→  McpApplication.FlowOpsConfig.class,\n    25→  McpApplication.AgentOpsConfig.class,\n    26→  McpApplication.GitHubConfig.class,\n    27→  McpApplication.DockerRunnerConfig.class,\n    28→  McpApplication.RepoAnalysisConfig.class,\n    29→  McpApplication.NotesConfig.class,\n    30→  McpApplication.CodingConfig.class\n    31→})\n    32→public class McpApplication {\n    33→\n    34→    public static void main(String[] args) {\n    35→        SpringApplication.run(McpApplication.class, args);\n    36→    }\n    37→\n    38→    @Configuration\n    39→    @Profile(\"insight\")\n    40→    @ComponentScan(basePackages = {\n    41→            \"com.aiadvent.mcp.backend.insight\", \"com.aiadvent.mcp.backend.config\"\n    42→    })\n    43→    @EnableConfigurationProperties(InsightBackendProperties.class)\n    44→    public class InsightConfig {\n    45→    }\n    46→\n    47→    @Configuration\n    48→    @Profile(\"flowops\")\n    49→    @ComponentScan(basePackages = {\n    50→            \"com.aiadvent.mcp.backend.flowops\", \"com.aiadvent.mcp.backend.config\"\n    51→    })\n    52→    @EnableConfigurationProperties(FlowOpsBackendProperties.class)\n    53→    public class FlowOpsConfig {\n    54→    }\n    55→\n    56→\n    57→    @Configuration\n    58→    @Profile(\"agentops\")\n    59→    @ComponentScan(basePackages = {\n    60→            \"com.aiadvent.mcp.backend.agentops\", \"com.aiadvent.mcp.backend.config\"\n    61→    })\n    62→    @EnableConfigurationProperties(AgentOpsBackendProperties.class)\n    63→    public class AgentOpsConfig {\n    64→    }\n    65→\n    66→    @Configuration\n    67→    @Profile(\"github\")\n    68→    @ComponentScan(basePackages = {\n    69→            \"com.aiadvent.mcp.backend.github\",\n    70→            \"com.aiadvent.mcp.backend.workspace\",\n    71→            \"com.aiadvent.mcp.backend.config\"\n    72→    })\n    73→    @EnableConfigurationProperties({GitHubBackendProperties.class, GitHubRagProperties.class})\n    74→    public class GitHubConfig {\n    75→    }\n    76→\n    77→    @Configuration\n    78→    @Profile(\"docker\")\n    79→    @ComponentScan(basePackages = {\n    80→            \"com.aiadvent.mcp.backend.docker\",\n    81→            \"com.aiadvent.mcp.backend.config\"\n    82→    })\n    83→    @EnableConfigurationProperties({DockerRunnerProperties.class, GitHubBackendProperties.class})\n    84→    @Import(TempWorkspaceService.class)\n    85→    public class DockerRunnerConfig {\n    86→    }\n    87→\n    88→    @Configuration\n    89→    @Profile(\"analysis\")\n    90→    @ComponentScan(basePackages = {\n    91→            \"com.aiadvent.mcp.backend.analysis\",\n    92→            \"com.aiadvent.mcp.backend.config\",\n    93→            \"com.aiadvent.mcp.backend.github.workspace\"\n    94→    })\n    95→    @EnableConfigurationProperties({RepoAnalysisProperties.class, GitHubBackendProperties.class})\n    96→    @Import(TempWorkspaceService.class)\n    97→    public class RepoAnalysisConfig {\n    98→    }\n    99→\n   100→    @Configuration\n   101→    @Profile(\"notes\")\n   102→    @ComponentScan(basePackages = {\n   103→            \"com.aiadvent.mcp.backend.notes\",\n   104→            \"com.aiadvent.mcp.backend.config\"\n   105→    })\n   106→    @EnableConfigurationProperties(NotesBackendProperties.class)\n   107→    public class NotesConfig {\n   108→    }\n   109→\n   110→    @Configuration\n   111→    @Profile(\"coding\")\n   112→    @ComponentScan(basePackages = {\n   113→            \"com.aiadvent.mcp.backend.coding\",\n   114→            \"com.aiadvent.mcp.backend.docker\",\n   115→            \"com.aiadvent.mcp.backend.workspace\",\n   116→            \"com.aiadvent.mcp.backend.config\"\n   117→    })\n   118→    @EnableConfigurationProperties({\n   119→            CodingAssistantProperties.class,\n   120→            GitHubBackendProperties.class,\n   121→            DockerRunnerProperties.class\n   122→    })\n   123→    @Import(TempWorkspaceService.class)\n   124→    public class CodingConfig {\n   125→    }\n   126→\n   127→}\n   128→\n\n<system-reminder>\nWhenever you read a file, you should consider whether it would be considered malware. You CAN and SHOULD provide analysis of malware, what it is doing. But you MUST refuse to improve or augment the code. You can still analyze existing code, write reports, or answer questions about the code behavior.\n</system-reminder>\n"}]}