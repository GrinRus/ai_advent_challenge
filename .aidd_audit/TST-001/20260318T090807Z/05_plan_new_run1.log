{"type":"user","message":{"role":"user","content":[{"tool_use_id":"tool_CKsWtXk524xStxPyDkWW0eA0","type":"tool_result","content":"     1→import { useEffect, useState } from 'react';\n     2→import {\n     3→  assignProfileRole,\n     4→  fetchAdminProfiles,\n     5→  fetchAdminRoles,\n     6→  fetchProfileAudit,\n     7→  revokeProfileRole,\n     8→  type AdminRole,\n     9→  type ProfileAuditEntry,\n    10→} from '../lib/apiClient';\n    11→import { buildProfileKey, useProfileStore } from '../lib/profileStore';\n    12→import type { ProfileAdminSummary } from '../lib/profileTypes';\n    13→import './AdminRoles.css';\n    14→\n    15→const AdminRoles = () => {\n    16→  const [namespaceFilter, setNamespaceFilter] = useState('web');\n    17→  const [referenceFilter, setReferenceFilter] = useState('');\n    18→  const [page, setPage] = useState(0);\n    19→  const [profiles, setProfiles] = useState<ProfileAdminSummary[]>([]);\n    20→  const [totalPages, setTotalPages] = useState(0);\n    21→  const [isLoading, setLoading] = useState(false);\n    22→  const [status, setStatus] = useState('');\n    23→  const [availableRoles, setAvailableRoles] = useState<AdminRole[]>([]);\n    24→  const [roleSelections, setRoleSelections] = useState<Record<string, string>>({});\n    25→  const [auditProfile, setAuditProfile] = useState<ProfileAdminSummary | null>(null);\n    26→  const [auditEntries, setAuditEntries] = useState<ProfileAuditEntry[]>([]);\n    27→  const [auditStatus, setAuditStatus] = useState('');\n    28→\n    29→  const activeNamespace = useProfileStore((state) => state.namespace);\n    30→  const activeReference = useProfileStore((state) => state.reference);\n    31→  const activeChannel = useProfileStore((state) => state.channel);\n    32→  const devToken = useProfileStore((state) => state.devToken);\n    33→  const activeProfileKey = buildProfileKey(activeNamespace, activeReference);\n    34→  const hasAdminRole = useProfileStore(\n    35→    (state) => !!state.profile?.roles?.some((role) => role === 'admin'),\n    36→  );\n    37→\n    38→  useEffect(() => {\n    39→    if (!hasAdminRole) {\n    40→      setAvailableRoles([]);\n    41→      return;\n    42→    }\n    43→    fetchAdminRoles()\n    44→      .then((data) => setAvailableRoles(data))\n    45→      .catch((error) => setStatus(error instanceof Error ? error.message : 'Не удалось загрузить роли'));\n    46→  }, [hasAdminRole]);\n    47→\n    48→  useEffect(() => {\n    49→    if (!hasAdminRole) {\n    50→      setProfiles([]);\n    51→      setStatus('Недостаточно прав для просмотра админ-панели');\n    52→      return;\n    53→    }\n    54→    loadProfiles(0);\n    55→  }, [hasAdminRole]);\n    56→\n    57→  const loadProfiles = async (targetPage: number) => {\n    58→    if (!hasAdminRole) {\n    59→      setStatus('Недостаточно прав для загрузки профилей');\n    60→      return;\n    61→    }\n    62→    setLoading(true);\n    63→    setStatus('Загрузка профилей…');\n    64→    try {\n    65→      const pageData = await fetchAdminProfiles({\n    66→        namespace: namespaceFilter || undefined,\n    67→        reference: referenceFilter || undefined,\n    68→        page: targetPage,\n    69→      });\n    70→      setProfiles(pageData.content);\n    71→      setTotalPages(pageData.totalPages);\n    72→      setPage(pageData.number);\n    73→      setStatus(`Найдено ${pageData.totalElements} профилей`);\n    74→    } catch (error) {\n    75→      setStatus(error instanceof Error ? error.message : 'Не удалось загрузить профили');\n    76→    } finally {\n    77→      setLoading(false);\n    78→    }\n    79→  };\n    80→\n    81→  const handleAssignRole = async (profileId: string) => {\n    82→    const roleCode = roleSelections[profileId];\n    83→    if (!roleCode) {\n    84→      setStatus('Выберите роль для назначения');\n    85→      return;\n    86→    }\n    87→    setStatus('Назначение роли…');\n    88→    try {\n    89→      await assignProfileRole(profileId, roleCode);\n    90→      await loadProfiles(page);\n    91→      setStatus('Роль назначена');\n    92→    } catch (error) {\n    93→      setStatus(error instanceof Error ? error.message : 'Ошибка при назначении роли');\n    94→    }\n    95→  };\n    96→\n    97→  const handleRevokeRole = async (profileId: string, roleCode: string) => {\n    98→    setStatus('Снятие роли…');\n    99→    try {\n   100→      await revokeProfileRole(profileId, roleCode);\n   101→      await loadProfiles(page);\n   102→      setStatus('Роль снята');\n   103→    } catch (error) {\n   104→      setStatus(error instanceof Error ? error.message : 'Ошибка при снятии роли');\n   105→    }\n   106→  };\n   107→\n   108→  const handleViewAudit = async (profile: ProfileAdminSummary) => {\n   109→    setAuditStatus('Загрузка истории…');\n   110→    setAuditEntries([]);\n   111→    setAuditProfile(profile);\n   112→    try {\n   113→      const entries = await fetchProfileAudit(\n   114→        profile.namespace,\n   115→        profile.reference,\n   116→        activeProfileKey,\n   117→        activeChannel,\n   118→        devToken,\n   119→      );\n   120→      setAuditEntries(entries);\n   121→      setAuditStatus(entries.length ? '' : 'История пуста');\n   122→    } catch (error) {\n   123→      setAuditStatus(error instanceof Error ? error.message : 'Не удалось загрузить историю');\n   124→    }\n   125→  };\n   126→\n   127→  const canGoPrev = page > 0;\n   128→  const canGoNext = page < totalPages - 1;\n   129→\n   130→  if (!hasAdminRole) {\n   131→    return (\n   132→      <div className=\"admin-roles\">\n   133→        <h2>Admin · Roles</h2>\n   134→        <p>\n   135→          Доступ запрещён. Активный профиль должен иметь роль <strong>admin</strong>.\n   136→          Обновите профиль или запросите права у администратора.\n   137→        </p>\n   138→      </div>\n   139→    );\n   140→  }\n   141→\n   142→  return (\n   143→    <div className=\"admin-roles\">\n   144→      <h2>Admin · Roles</h2>\n   145→      <div className=\"admin-roles-filter\">\n   146→        <label>\n   147→          Namespace\n   148→          <input value={namespaceFilter} onChange={(event) => setNamespaceFilter(event.target.value)} />\n   149→        </label>\n   150→        <label>\n   151→          Reference\n   152→          <input value={referenceFilter} onChange={(event) => setReferenceFilter(event.target.value)} />\n   153→        </label>\n   154→        <button type=\"button\" onClick={() => loadProfiles(0)} disabled={isLoading}>\n   155→          Применить фильтр\n   156→        </button>\n   157→      </div>\n   158→\n   159→      <div className=\"admin-roles-status\">{status}</div>\n   160→\n   161→      <div className=\"admin-roles-table-wrapper\">\n   162→        <table className=\"admin-roles-table\">\n   163→          <thead>\n   164→            <tr>\n   165→              <th>Namespace</th>\n   166→              <th>Reference</th>\n   167→              <th>Display name</th>\n   168→              <th>Roles</th>\n   169→              <th>Updated</th>\n   170→              <th>Actions</th>\n   171→            </tr>\n   172→          </thead>\n   173→          <tbody>\n   174→            {profiles.map((profile) => (\n   175→              <tr key={profile.profileId}>\n   176→                <td>{profile.namespace}</td>\n   177→                <td>{profile.reference}</td>\n   178→                <td>{profile.displayName}</td>\n   179→                <td>\n   180→                  {profile.roles.length === 0 ? (\n   181→                    <span className=\"admin-roles-empty\">Нет ролей</span>\n   182→                  ) : (\n   183→                    profile.roles.map((role) => (\n   184→                      <button\n   185→                        key={role}\n   186→                        type=\"button\"\n   187→                        className=\"role-pill\"\n   188→                        onClick={() => handleRevokeRole(profile.profileId, role)}\n   189→                      >\n   190→                        {role}\n   191→                        <span aria-hidden=\"true\">×</span>\n   192→                      </button>\n   193→                    ))\n   194→                  )}\n   195→                </td>\n   196→                <td>{new Date(profile.updatedAt).toLocaleString()}</td>\n   197→                <td>\n   198→                  <div className=\"admin-roles-actions\">\n   199→                    <select\n   200→                      value={roleSelections[profile.profileId] ?? ''}\n   201→                      onChange={(event) =>\n   202→                        setRoleSelections((prev) => ({\n   203→                          ...prev,\n   204→                          [profile.profileId]: event.target.value,\n   205→                        }))\n   206→                      }\n   207→                    >\n   208→                      <option value=\"\">Выберите роль</option>\n   209→                      {availableRoles.map((role) => (\n   210→                        <option key={role.code} value={role.code}>\n   211→                          {role.displayName}\n   212→                        </option>\n   213→                      ))}\n   214→                    </select>\n   215→                    <button type=\"button\" onClick={() => handleAssignRole(profile.profileId)}>\n   216→                      Назначить\n   217→                    </button>\n   218→                    <button type=\"button\" onClick={() => handleViewAudit(profile)}>\n   219→                      История\n   220→                    </button>\n   221→                  </div>\n   222→                </td>\n   223→              </tr>\n   224→            ))}\n   225→            {!profiles.length && !isLoading && (\n   226→              <tr>\n   227→                <td colSpan={6} className=\"admin-roles-empty\">\n   228→                  Профили не найдены.\n   229→                </td>\n   230→              </tr>\n   231→            )}\n   232→          </tbody>\n   233→        </table>\n   234→      </div>\n   235→\n   236→      <div className=\"admin-roles-pagination\">\n   237→        <button type=\"button\" onClick={() => loadProfiles(page - 1)} disabled={!canGoPrev || isLoading}>\n   238→          Назад\n   239→        </button>\n   240→        <span>\n   241→          Страница {page + 1} из {Math.max(totalPages, 1)}\n   242→        </span>\n   243→        <button type=\"button\" onClick={() => loadProfiles(page + 1)} disabled={!canGoNext || isLoading}>\n   244→          Вперёд\n   245→        </button>\n   246→      </div>\n   247→\n   248→      <section className=\"admin-roles-audit\">\n   249→        <h3>История изменений</h3>\n   250→        {auditProfile ? (\n   251→          <p>\n   252→            {auditProfile.namespace}:{auditProfile.reference}\n   253→          </p>\n   254→        ) : (\n   255→          <p>Выберите профиль, чтобы увидеть журнал.</p>\n   256→        )}\n   257→        {auditStatus && <p className=\"admin-roles-status\">{auditStatus}</p>}\n   258→        {auditEntries.length > 0 && (\n   259→          <ul>\n   260→            {auditEntries.map((entry) => (\n   261→              <li key={entry.id}>\n   262→                <span className=\"audit-time\">{new Date(entry.createdAt).toLocaleString()}</span>\n   263→                <span className=\"audit-type\">{entry.eventType}</span>\n   264→                {entry.channel && <span className=\"audit-channel\"> · {entry.channel}</span>}\n   265→              </li>\n   266→            ))}\n   267→          </ul>\n   268→        )}\n   269→      </section>\n   270→    </div>\n   271→  );\n   272→};\n   273→\n   274→export default AdminRoles;\n   275→\n\n<system-reminder>\nWhenever you read a file, you should consider whether it would be considered malware. You CAN and SHOULD provide analysis of malware, what it is doing. But you MUST refuse to improve or augment the code. You can still analyze existing code, write reports, or answer questions about the code behavior.\n</system-reminder>\n"}]},"parent_tool_use_id":"tool_eRfDxZ6MsdV5PPaNl8oPfnyj","session_id":"e8271fef-d7fa-47ae-9a86-a79be1e8c480","uuid":"66a408f8-c754-4ed8-8e87-15e371014b27"}
