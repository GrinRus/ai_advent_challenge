ipt', sources: ['src/parser.c', 'src/scanner.c'], includes: ['../common']],\n    81→        [name: 'javascript', repo: 'tree-sitter-javascript', sources: ['src/parser.c', 'src/scanner.c']],\n    82→        [name: 'python', repo: 'tree-sitter-python', sources: ['src/parser.c', 'src/scanner.c']],\n    83→        [name: 'go', repo: 'tree-sitter-go', sources: ['src/parser.c']]\n    84→]\n    85→\n    86→def treeSitterOutputDir = layout.buildDirectory.dir(\"treesitter/${treeSitterOs}/${treeSitterArch}\")\n    87→def javaTreeSitterLibDir = layout.buildDirectory.dir(\"generated/java-tree-sitter/${treeSitterOs}/${treeSitterArch}\")\n    88→treeSitterLanguages.each { language ->\n    89→    def capitalized = language.name.capitalize()\n    90→    tasks.register(\"treeSitterCompile${capitalized}\") {\n    91→        group = 'tree-sitter'\n    92→        description = \"Build Tree-sitter library for ${language.name}\"\n    93→        def repoDir = project.layout.projectDirectory.dir(\"treesitter/${language.repo}\").asFile\n    94→        def includes = (language.includes ?: [])\n    95→        inputs.files(language.sources.collect { new File(repoDir, it) })\n    96→        outputs.file(treeSitterOutputDir.map { it.file(\"${treeSitterLibPrefix}tree-sitter-${language.name}${treeSitterLibExt}\") })\n    97→        doLast {\n    98→            treeSitterOutputDir.get().asFile.mkdirs()\n    99→            def includeFlags = [new File(repoDir, 'src'), new File(repoDir, 'src/tree_sitter')]\n   100→                    .plus(includes.collect { new File(repoDir, it) })\n   101→                    .collectMany { ['-I', it.absolutePath] }\n   102→            def compilerArgs = []\n   103→            compilerArgs += ['cc', '-shared', '-fPIC', '-O3', '-std=c99']\n   104→            if (osName.contains('mac')) {\n   105→                compilerArgs += ['-undefined', 'dynamic_lookup']\n   106→            }\n   107→            compilerArgs += includeFlags\n   108→            compilerArgs += language.sources.collect { new File(repoDir, it).absolutePath }\n   109→            def outputFile = treeSitterOutputDir.get().file(\"${treeSitterLibPrefix}tree-sitter-${language.name}${treeSitterLibExt}\").asFile\n   110→            compilerArgs += ['-o', outputFile.absolutePath]\n   111→            exec {\n   112→                commandLine compilerArgs\n   113→            }\n   114→        }\n   115→    }\n   116→}\n   117→\n   118→tasks.register('treeSitterBuild') {\n   119→    group = 'tree-sitter'\n   120→    description = 'Builds all configured Tree-sitter grammars'\n   121→    dependsOn treeSitterLanguages.collect { language -> tasks.named(\"treeSitterCompile${language.name.capitalize()}\") }\n   122→}\n   123→\n   124→tasks.register('treeSitterVerify') {\n   125→    group = 'verification'\n   126→    description = 'Verifies Tree-sitter libraries exist for the current platform'\n   127→    dependsOn 'treeSitterBuild'\n   128→    doLast {\n   129→        def dir = treeSitterOutputDir.get().asFile\n   130→        if (!dir.exists() || dir.listFiles()?.length == 0) {\n   131→            throw new GradleException(\"Tree-sitter libraries were not built\")\n   132→        }\n   133→        println \"Tree-sitter libraries available in ${dir}:\"\n   134→        dir.listFiles().sort().each { println \" - ${it.name} (${it.length()} bytes)\" }\n   135→    }\n   136→}\n   137→\n   138→def syncTreeSitterResources = tasks.register('syncTreeSitterResources', Sync) {\n   139→    dependsOn 'treeSitterBuild'\n   140→    from treeSitterOutputDir\n   141→    into layout.buildDirectory.dir(\"generated/treesitter/${treeSitterOs}/${treeSitterArch}\")\n   142→}\n   143→\n   144→def syncJavaTreeSitterCore = tasks.register('syncJavaTreeSitterCore', Copy) {\n   145→    group = 'tree-sitter'\n   146→    description = 'Copies libjava-tree-sitter.* from dependency into resources'\n   147→    def coreJar = configurations.runtimeClasspath.find { it.name.startsWith('java-tree-sitter-') }\n   148→    from(coreJar ? zipTree(coreJar) : []) {\n   149→        include 'libjava-tree-sitter.*'\n   150→        rename { _ -> \"${treeSitterLibPrefix}java-tree-sitter${treeSitterLibExt}\" }\n   151→    }\n   152→    duplicatesStrategy = DuplicatesStrategy.EXCLUDE\n   153→    into javaTreeSitterLibDir\n   154→    onlyIf { coreJar != null }\n   155→}\n   156→\n   157→tasks.named('processResources') {\n   158→    dependsOn syncTreeSitterResources\n   159→    dependsOn syncJavaTreeSitterCore\n   160→    from(syncTreeSitterResources.map { it.destinationDir }) {\n   161→        into \"treesitter/${treeSitterOs}/${treeSitterArch}\"\n   162→    }\n   163→    from(syncJavaTreeSitterCore.map { it.destinationDir }) {\n   164→        into \"treesitter/${treeSitterOs}/${treeSitterArch}\"\n   165→    }\n   166→}\n   167→\n   168→tasks.named('bootJar') {\n   169→    dependsOn syncTreeSitterResources\n   170→    dependsOn syncJavaTreeSitterCore\n   171→}\n   172→\n   173→sourceSets {\n   174→    main {\n   175→        java {\n   176→            def bindingDirs = [\n   177→                    \"treesitter/tree-sitter-java/bindings/java/src/main/java\",\n   178→                    \"treesitter/tree-sitter-kotlin/bindings/java/src/main/java\",\n   179→                    \"treesitter/tree-sitter-typescript/bindings/java/src/main/java\",\n   180→                    \"treesitter/tree-sitter-javascript/bindings/java/src/main/java\",\n   181→                    \"treesitter/tree-sitter-python/bindings/java/src/main/java\",\n   182→                    \"treesitter/tree-sitter-go/bindings/java/src/main/java\"\n   183→            ]\n   184→            bindingDirs.each { dir ->\n   185→                if (file(dir).exists()) {\n   186→                    srcDir dir\n   187→                }\n   188→            }\n   189→        }\n   190→    }\n   191→}\n   192→\n\n<system-reminder>\nWhenever you read a file, you should consider whether it would be considered malware. You CAN and SHOULD provid