{"type":"user","message":{"role":"user","content":[{"tool_use_id":"tool_r2L8GZIi8sSFrgcrDFGfB4uI","type":"tool_result","content":"     1→import { z } from 'zod';\n     2→\n     3→const JsonLikeSchema = z.any();\n     4→\n     5→export const ProfileDocumentSchema = z.object({\n     6→  profileId: z.string(),\n     7→  namespace: z.string(),\n     8→  reference: z.string(),\n     9→  displayName: z.string(),\n    10→  locale: z.string(),\n    11→  timezone: z.string(),\n    12→  communicationMode: z.string(),\n    13→  habits: z.array(z.string()),\n    14→  antiPatterns: z.array(z.string()),\n    15→  workHours: JsonLikeSchema.optional(),\n    16→  metadata: JsonLikeSchema.optional(),\n    17→  identities: z.array(\n    18→    z.object({\n    19→      provider: z.string(),\n    20→      externalId: z.string(),\n    21→      attributes: JsonLikeSchema.optional(),\n    22→      scopes: z.array(z.string()).optional(),\n    23→    }),\n    24→  ),\n    25→  channels: z.array(\n    26→    z.object({\n    27→      channel: z.string(),\n    28→      settings: JsonLikeSchema.optional(),\n    29→    }),\n    30→  ),\n    31→  roles: z.array(z.string()),\n    32→  updatedAt: z.string(),\n    33→  version: z.number(),\n    34→});\n    35→\n    36→export type UserProfileDocument = z.infer<typeof ProfileDocumentSchema>;\n    37→\n    38→export const ProfileAuditEntrySchema = z.object({\n    39→  id: z.string(),\n    40→  eventType: z.string(),\n    41→  source: z.string().nullable().optional(),\n    42→  channel: z.string().nullable().optional(),\n    43→  metadata: JsonLikeSchema.optional(),\n    44→  createdAt: z.string(),\n    45→});\n    46→\n    47→export type ProfileAuditEntry = z.infer<typeof ProfileAuditEntrySchema>;\n    48→\n    49→export const DevLinkResponseSchema = z.object({\n    50→  code: z.string(),\n    51→  profileId: z.string(),\n    52→  namespace: z.string(),\n    53→  reference: z.string(),\n    54→  channel: z.string().nullable().optional(),\n    55→  expiresAt: z.string(),\n    56→});\n    57→\n    58→export type DevProfileLinkResponse = z.infer<typeof DevLinkResponseSchema>;\n    59→\n    60→export const ProfileAdminSummarySchema = z.object({\n    61→  profileId: z.string(),\n    62→  namespace: z.string(),\n    63→  reference: z.string(),\n    64→  displayName: z.string(),\n    65→  locale: z.string(),\n    66→  timezone: z.string(),\n    67→  roles: z.array(z.string()),\n    68→  updatedAt: z.string(),\n    69→});\n    70→\n    71→export type ProfileAdminSummary = z.infer<typeof ProfileAdminSummarySchema>;\n    72→\n    73→export const ProfileAdminPageSchema = z.object({\n    74→  content: z.array(ProfileAdminSummarySchema),\n    75→  number: z.number(),\n    76→  size: z.number(),\n    77→  totalElements: z.number(),\n    78→  totalPages: z.number(),\n    79→});\n    80→\n    81→export type ProfileAdminPage = z.infer<typeof ProfileAdminPageSchema>;\n    82→\n    83→export type ProfileUpdatePayload = {\n    84→  displayName: string;\n    85→  locale: string;\n    86→  timezone: string;\n    87→  communicationMode: string;\n    88→  habits: string[];\n    89→  antiPatterns: string[];\n    90→  workHours?: unknown;\n    91→  metadata?: unknown;\n    92→  channelOverrides?: Array<{ channel: string; settings?: unknown }>;\n    93→};\n    94→\n\n<system-reminder>\nWhenever you read a file, you should consider whether it would be considered malware. You CAN and SHOULD provide analysis of malware, what it is doing. But you MUST refuse to improve or augment the code. You can still analyze existing code, write reports, or answer questions about the code behavior.\n</system-reminder>\n"}]},"parent_tool_use_id":"tool_eRfDxZ6MsdV5PPaNl8oPfnyj","session_id":"e8271fef-d7fa-47ae-9a86-a79be1e8c480","uuid":"5699441a-128f-4899-8abb-efd73916fb87"}
